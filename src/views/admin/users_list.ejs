<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Người dùng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header', {
        user,
        active: 'users',
        backUrl: '/redirect',
        breadcrumb: [
            { label: 'Quản trị', url: '/users' },
            { label: 'Người dùng' }
        ]
    }) %>
    <div class="container mt-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0" data-help="Quản lý tài khoản được phép truy cập trang quản trị và phạm vi quyền của từng người.">Người dùng</h3>
            <div></div>
        </div>
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-bold"><span data-help="Tài khoản Inactive không thể đăng nhập nhưng lịch sử thao tác vẫn được giữ lại.">Danh sách</span></div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>#</th><th>Tài khoản</th><th>Role</th><th>Trạng thái</th><th>Ngày tạo</th><th class="text-end">Hành động</th></tr>
                    </thead>
                    <tbody>
                        <% users.forEach((u, idx) => { %>
                            <tr>
                                <td><%= idx + 1 %></td>
                                <td><%= u.username %></td>
                                <td><span class="badge <%= u.role_name==='super_admin' ? 'bg-danger' : 'bg-secondary' %>"><%= u.role_name %></span></td>
                                <td><span class="badge <%= u.is_active ? 'bg-success' : 'bg-warning' %>"><%= u.is_active ? 'Active' : 'Inactive' %></span></td>
                                <td><%= new Date(u.created_at).toLocaleString('vi-VN') %></td>
                                <td class="text-end">
                                    <a href="/users/view/<%= u.id %>" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                    <% if (currentUserRole==='super_admin') { %>
                                        <form action="/users/delete/<%= u.id %>" method="POST" class="d-inline" onsubmit="return confirm('Vô hiệu hóa tài khoản và thu hồi quyền domain? Domain đang sở hữu sẽ chuyển cho super admin hiện tại. Tiếp tục?')">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn btn-sm btn-danger">Vô hiệu hóa</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white fw-bold"><span data-help="Mỗi người vận hành nên có tài khoản riêng để nhật ký quản trị ghi đúng người thực hiện.">Tạo người dùng</span></div>
            <form class="card-body" action="/users/create" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" data-help="Tên đăng nhập duy nhất. Nên dùng tên dễ nhận diện theo người vận hành.">Username</label>
                        <input type="text" name="username" class="form-control" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" data-help="Dùng mật khẩu riêng, tối thiểu 6 ký tự và không gửi qua kênh công khai.">Password</label>
                        <input type="password" name="password" class="form-control" minlength="6" autocomplete="new-password" required>
                    </div>
                </div>
                <div class="mt-3 text-end">
                    <button class="btn btn-primary">Tạo</button>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
