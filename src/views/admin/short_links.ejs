<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Link chờ chuyển hướng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', {
    user,
    active: 'short-links',
    breadcrumb: [{ label: 'Link chờ chuyển hướng' }]
  }) %>

  <div class="container-xxl pb-5 mt-3">
    <div class="row g-4">
      <div class="col-xl-4">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-header bg-white border-0 pt-4 px-4">
            <div class="d-flex align-items-center gap-3">
              <div class="brand-mark"><i class="fa-solid fa-arrow-up-right-from-square"></i></div>
              <div>
                <h1 class="h5 mb-1" data-help="Luồng này không kiểm tra campaign, quốc gia, thiết bị hoặc tham số. Trang chờ được hiển thị trong khoảng thời gian bạn đặt rồi tự động chuyển tới link đích.">Tạo link chờ chuyển hướng</h1>
                <p class="text-muted small mb-0">Luồng 2 · Tự động chuyển sau thời gian chờ.</p>
              </div>
            </div>
          </div>

          <form class="card-body p-4" action="/short-links/create" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="mb-3">
              <label class="form-label fw-bold" data-help="Chọn domain sẽ tạo đường dẫn /s/mã-ngắn. Domain cần hoạt động và đã trỏ DNS về VPS.">Domain</label>
              <select name="domain_id" class="form-select" required <%= domains.length ? '' : 'disabled' %>>
                <% domains.forEach((domain) => { %>
                  <option value="<%= domain.id %>"><%= domain.domain_url %><%= domain.status === 'active' ? '' : ' (inactive)' %></option>
                <% }) %>
              </select>
              <% if (!domains.length) { %>
                <div class="form-text text-danger">Cần tạo domain trước khi tạo link.</div>
              <% } %>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold" data-help="Tên nội bộ để dễ tìm trong danh sách và báo cáo; người truy cập không nhìn thấy tên này.">Tên link</label>
              <input type="text" name="title" class="form-control" maxlength="150" placeholder="VD: Landing khuyến mãi" required>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold" data-help="URL cuối cùng người dùng sẽ được chuyển tới. Tham số trên link truy cập được nối tiếp nếu link đích chưa có cùng key.">Link đích</label>
              <input type="url" name="target_url" class="form-control" placeholder="https://example.com/landing" required>
              <div class="form-text">Các tham số trên link truy cập sẽ được chuyển tiếp sang link đích.</div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold" data-help="Số giây hiển thị trang đếm ngược trước khi tự động chuyển. Giới hạn 1–30 giây để tránh giữ người dùng quá lâu.">Thời gian chờ</label>
              <div class="input-group">
                <input type="number" name="redirect_delay_seconds" class="form-control" min="1" max="30" step="1" value="3" required>
                <span class="input-group-text">giây</span>
              </div>
              <div class="form-text">Trang chờ trả HTTP 200 rồi tự động chuyển; không chạy bộ lọc tham số.</div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-bold" data-help="Phần nằm sau /s/. Để trống để hệ thống tạo mã ngẫu nhiên không trùng trên domain đã chọn.">Mã ngắn</label>
              <div class="input-group">
                <span class="input-group-text">/s/</span>
                <input type="text" name="code" class="form-control" pattern="[a-z0-9_-]{3,80}" placeholder="để trống để tự sinh">
              </div>
              <div class="form-text">Chỉ dùng a-z, 0-9, gạch ngang hoặc gạch dưới.</div>
            </div>

            <button class="btn btn-primary w-100" type="submit" <%= domains.length ? '' : 'disabled' %>>
              <i class="fa-solid fa-plus me-2"></i>Tạo link
            </button>
          </form>
        </div>
      </div>

      <div class="col-xl-8">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-white border-0 pt-4 px-4 d-flex align-items-center justify-content-between">
            <div>
              <h2 class="h5 mb-1" data-help="Theo dõi link, số click, trạng thái và chế độ chuyển. Tắt link sẽ đưa người dùng về giao diện dự phòng của domain.">Danh sách link</h2>
              <p class="text-muted small mb-0">Tất cả link trong luồng này đều hiển thị trang chờ trước khi chuyển.</p>
            </div>
            <span class="badge rounded-pill text-bg-primary"><%= links.length %> link</span>
          </div>
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <thead class="table-light">
                <tr>
                  <th>Tên</th>
                  <th>Link sử dụng</th>
                  <th>Chế độ</th>
                  <th>Click</th>
                  <th>Trạng thái</th>
                  <th class="text-end">Hành động</th>
                </tr>
              </thead>
              <tbody>
                <% if (!links.length) { %>
                  <tr><td colspan="6" class="text-center py-5 text-muted">Chưa có link chuyển hướng nào.</td></tr>
                <% } %>
                <% links.forEach((link) => { %>
                  <tr>
                    <td style="min-width:210px">
                      <div class="fw-bold"><%= link.title || link.code %></div>
                      <small class="text-muted d-block text-truncate" style="max-width:260px"><%= link.target_url %></small>
                      <small class="text-muted">Tạo bởi <%= link.created_by_name || 'N/A' %></small>
                    </td>
                    <td style="min-width:260px">
                      <div class="input-group input-group-sm">
                        <input type="text" class="form-control bg-white text-primary fw-bold" value="<%= link.full_url %>" readonly id="short-link-<%= link.id %>">
                        <button type="button" class="btn btn-primary" onclick="copyShortLink('short-link-<%= link.id %>', this)" title="Copy link">
                          <i class="fa-solid fa-copy"></i>
                        </button>
                      </div>
                      <div class="mt-1"><span class="badge bg-light text-secondary border">/s/<%= link.code %></span></div>
                    </td>
                    <td>
                      <span class="badge text-bg-warning"><i class="fa-regular fa-clock me-1"></i>Chờ <%= link.redirect_delay_seconds || 3 %> giây</span>
                    </td>
                    <td><strong><%= link.clicks || 0 %></strong></td>
                    <td>
                      <form action="/short-links/toggle/<%= link.id %>" method="POST" class="d-inline" onsubmit="return confirm('Đổi trạng thái link này?')">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-sm <%= link.is_active ? 'btn-success' : 'btn-danger' %>"><%= link.is_active ? 'ON' : 'OFF' %></button>
                      </form>
                    </td>
                    <td class="text-end text-nowrap">
                      <a href="/short-links/<%= link.id %>/report" class="btn btn-sm btn-info text-white" title="Báo cáo"><i class="fa-solid fa-chart-line"></i></a>
                      <a href="/short-links/<%= link.id %>/logs" class="btn btn-sm btn-outline-secondary">Log</a>
                      <% if (user.role_name === 'super_admin') { %>
                        <form action="/short-links/delete/<%= link.id %>" method="POST" class="d-inline" onsubmit="return confirm('Xóa link này?')">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-danger"><i class="fa-solid fa-trash"></i></button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    async function copyShortLink(id, button) {
      const input = document.getElementById(id);
      try {
        await navigator.clipboard.writeText(input.value);
      } catch (_) {
        input.select();
        document.execCommand("copy");
      }
      const original = button.innerHTML;
      button.innerHTML = '<i class="fa-solid fa-check"></i>';
      window.setTimeout(() => { button.innerHTML = original; }, 1200);
    }
  </script>
  <%- include('../partials/footer') %>
</body>
</html>
