<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chiến dịch · <%= product.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header', { user, active: 'redirect', breadcrumb: [{ label: 'Chiến dịch' }] }) %>
  <div class="container-xxl">
    <section class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
      <div>
        <p class="eyebrow mb-1">Trung tâm điều phối</p>
        <h1 class="h2 fw-bold mb-2" data-help="Mỗi domain có một Safe Page và chứa cả hai loại link: kiểm tra tham số hoặc tự chuyển sau thời gian chờ.">Tên miền &amp; Link</h1>
        <p class="text-muted mb-0">Chọn một domain để xem Safe Page và tạo một trong hai loại link.</p>
      </div>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDomainModal">
        <i class="fa-solid fa-plus me-2"></i>Thêm domain
      </button>
    </section>

    <section class="metric-grid mb-4">
      <div class="metric-card">
        <div class="metric-icon blue"><i class="fa-solid fa-globe"></i></div>
        <div><span>Domain</span><strong><%= Number(stats.total_domains || 0).toLocaleString('vi-VN') %></strong><small>Đang quản lý</small></div>
      </div>
      <div class="metric-card">
        <div class="metric-icon violet"><i class="fa-solid fa-route"></i></div>
        <div><span>Chiến dịch</span><strong><%= Number(stats.total_links || 0).toLocaleString('vi-VN') %></strong><small>Tổng cấu hình</small></div>
      </div>
      <div class="metric-card">
        <div class="metric-icon green"><i class="fa-solid fa-arrow-trend-up"></i></div>
        <div><span>Lượt qua link</span><strong><%= Number(stats.total_traffic || 0).toLocaleString('vi-VN') %></strong><small data-help="Link điều kiện được tính khi server trả redirect. Link chờ chỉ được tính khi trình duyệt xác nhận hết thời gian chờ. Truy cập thẳng, Safe Page và probe không làm tăng số này.">Không tính Safe Page/probe</small></div>
      </div>
    </section>

    <section class="card domain-table-card">
      <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between flex-wrap gap-2 px-4 py-3">
        <div><h2 class="h6 fw-bold mb-1" data-help="Danh sách toàn bộ domain đã kết nối. Nút Quản lý mở cấu hình chiến dịch, giao diện dự phòng và báo cáo của domain.">Danh sách domain</h2><p class="text-muted small mb-0">Cấu hình mới có thể mất tối đa 30 giây để đồng bộ cache.</p></div>
        <span class="badge text-bg-light"><%= domains.length %> domain</span>
      </div>
      <% if (!domains.length) { %>
        <div class="empty-state">
          <div class="empty-icon"><i class="fa-solid fa-globe"></i></div>
          <h3>Chưa có domain nào</h3>
          <p>Thêm domain đầu tiên để bắt đầu tạo chiến dịch redirect.</p>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDomainModal"><i class="fa-solid fa-plus me-2"></i>Thêm domain đầu tiên</button>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead><tr><th class="ps-4">Domain</th><th>Giao diện</th><th>SSL</th><th>Trạng thái</th><th>Tổng link</th><th>Lượt qua link</th><th class="text-end pe-4">Thao tác</th></tr></thead>
            <tbody>
              <% domains.forEach(d => { %>
                <tr>
                  <td class="ps-4">
                    <div class="domain-cell"><div class="domain-avatar"><%= d.domain_url.substring(0, 1).toUpperCase() %></div><div><a href="/domains/<%= d.id %>" class="fw-bold text-dark text-decoration-none"><%= d.domain_url %></a><div class="text-muted small">Bấm vào domain để quản lý link</div></div></div>
                  </td>
                  <td><span class="badge bg-light text-dark border"><%= d.safe_template === 'age_gate' ? 'Safe Page 2 · 18+' : 'Safe Page 1 · Repair' %></span></td>
                  <td>
                    <% if (d.ssl_status === 'active') { %><span class="badge bg-success">SSL hoạt động</span>
                    <% } else if (d.ssl_status === 'provisioning' || d.ssl_status === 'pending') { %><span class="badge bg-warning text-dark">Đang cấp SSL</span>
                    <% } else if (d.ssl_status === 'error') { %><span class="badge bg-danger">SSL lỗi</span>
                    <% } else { %><span class="badge bg-info text-dark">TLS Cloudflare</span><% } %>
                  </td>
                  <td><span class="status-badge <%= d.status === 'active' ? 'active' : 'inactive' %>"><span class="status-dot"></span><%= d.status === 'active' ? 'Hoạt động' : 'Đã tắt' %></span></td>
                  <td><div class="campaign-count"><strong><%= d.link_active || 0 %></strong> hoạt động <span>/ <%= d.link_count || 0 %> tổng</span></div></td>
                  <td><strong class="text-success"><%= Number(d.traffic_count || 0).toLocaleString('vi-VN') %></strong><div class="text-muted small">redirect thành công</div></td>
                  <td class="text-end pe-4 text-nowrap">
                    <form action="/domains/toggle/<%= d.id %>" method="POST" class="d-inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm btn-outline-secondary" title="Bật/tắt"><i class="fa-solid fa-power-off"></i></button></form>
                    <a href="https://<%= d.domain_url %>" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary ms-1" title="Xem Safe Page"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                    <a href="/domains/<%= d.id %>" class="btn btn-sm btn-primary ms-1">Mở domain</a>
                    <form action="/domains/delete/<%= d.id %>" method="POST" class="d-inline" onsubmit="return confirm('Xóa domain sẽ xóa toàn bộ chiến dịch và log liên quan. Tiếp tục?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm btn-outline-danger ms-1" title="Xóa"><i class="fa-solid fa-trash"></i></button></form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </div>

  <div class="modal fade" id="addDomainModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <form class="modal-content" action="/domains/create" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-header"><div><h5 class="modal-title fw-bold" data-help="Tạo điểm vào mới cho hệ thống. Sau khi lưu, hệ thống tự xếp hàng kiểm tra và cấp SSL.">Thêm domain</h5><p class="text-muted small mb-0">Hãy cấu hình DNS trước; SSL sẽ được cấp tự động sau khi lưu.</p></div><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-3"><label class="form-label fw-bold" data-help="Nhập hostname thuần, ví dụ go.example.com. Không thêm giao thức, cổng hoặc đường dẫn.">Tên domain</label><input type="text" name="domain_url" class="form-control" required placeholder="go.example.com"><div class="form-text">Chỉ nhập tên miền, không nhập http:// hoặc đường dẫn.</div></div>
          <div class="mb-2"><label class="form-label fw-bold" data-help="Chọn một lần khi thêm domain. Mẫu này áp dụng cho toàn bộ campaign và nội dung Safe Page luôn bằng tiếng Anh.">Giao diện Safe Page</label><select name="safe_template" class="form-select"><option value="clean">Safe Page 1 — Repair Services</option><option value="age_gate">Safe Page 2 — 18+ Age Confirmation</option></select><div class="form-text">Không thể đổi mẫu trong campaign hoặc trang chi tiết domain.</div></div>
          <div class="alert alert-light border small mt-3 mb-0"><i class="fa-solid fa-shield-halved text-success me-2"></i><%= sslAutomationEnabled ? 'Auto SSL đang bật. Quá trình cấp chứng chỉ chạy nền và có thể mất vài phút.' : 'Máy chủ đang dùng TLS Cloudflare dự phòng; Auto SSL riêng chưa được bật.' %></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu domain</button></div>
      </form>
    </div>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
