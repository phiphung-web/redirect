<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Log link tự chuyển - <%= link.title || link.code %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <% const projectOnlyView = typeof resourceReadOnly !== 'undefined' && resourceReadOnly && link.project_id; %>
  <%- include('../partials/header', {
    user,
    active: projectOnlyView ? 'projects' : 'short-links',
    backUrl: projectOnlyView ? '/projects/' + link.project_id : '/short-links/' + link.id + '/report',
    breadcrumb: projectOnlyView ? [
      { label: 'Dự án', url: '/projects/' + link.project_id },
      { label: link.title || link.code, url: '/short-links/' + link.id + '/report' },
      { label: 'Log' }
    ] : [
      { label: link.domain_url, url: '/domains/' + link.domain_id },
      { label: 'Link tự chuyển' },
      { label: link.title || link.code, url: '/short-links/' + link.id + '/report' },
      { label: 'Log' }
    ]
  }) %>

  <div class="container bg-white p-4 rounded shadow-sm mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h4 class="mb-0" data-help="Danh sách chi tiết các lượt mở link chuyển hướng, gồm IP, quốc gia, thiết bị, referer và URL request.">Log: <span class="text-primary"><%= link.title || link.code %></span></h4>
        <small class="text-muted">https://<%= link.domain_url %>/s/<%= link.code %></small>
      </div>
    </div>

    <form class="row g-2 mb-3" method="GET">
      <div class="col-auto">
        <label class="form-label">Trạng thái</label>
        <select name="status" class="form-select form-select-sm">
          <option value="" <%= !status ? 'selected' : '' %>>Tất cả</option>
          <option value="confirmed" <%= status==='confirmed' ? 'selected' : '' %>>Đã chuyển hướng</option>
          <option value="unconfirmed" <%= status==='unconfirmed' ? 'selected' : '' %>>Chưa xác nhận</option>
          <option value="legacy" <%= status==='legacy' ? 'selected' : '' %>>Dữ liệu cũ</option>
        </select>
      </div>
      <div class="col-auto">
        <label class="form-label">Từ ngày</label>
        <input type="date" name="start_date" value="<%= startDateValue %>" class="form-control form-control-sm">
      </div>
      <div class="col-auto">
        <label class="form-label">Đến ngày</label>
        <input type="date" name="end_date" value="<%= endDateValue %>" class="form-control form-control-sm">
      </div>
      <div class="col-auto">
        <label class="form-label">Quốc gia</label>
        <input type="text" name="country" value="<%= country %>" maxlength="8" placeholder="VD: PH" class="form-control form-control-sm text-uppercase">
      </div>
      <div class="col-auto">
        <label class="form-label">Thiết bị</label>
        <select name="device" class="form-select form-select-sm">
          <option value="" <%= !device ? 'selected' : '' %>>Tất cả</option>
          <option value="mobile" <%= device==='mobile' ? 'selected' : '' %>>Mobile</option>
          <option value="desktop" <%= device==='desktop' ? 'selected' : '' %>>Desktop</option>
          <option value="pc" <%= device==='pc' ? 'selected' : '' %>>PC</option>
          <option value="tablet" <%= device==='tablet' ? 'selected' : '' %>>Tablet</option>
          <option value="unknown" <%= device==='unknown' ? 'selected' : '' %>>Không xác định</option>
        </select>
      </div>
      <div class="col-auto">
        <label class="form-label">IP</label>
        <input type="text" name="ip" value="<%= ip %>" maxlength="64" placeholder="IP chính xác" class="form-control form-control-sm">
      </div>
      <div class="col-auto">
        <label class="form-label" data-help="Giới hạn số bản ghi tải trong một lần, tối đa 2.000 dòng.">Số dòng</label>
        <input type="number" name="limit" value="<%= limit %>" min="50" max="2000" class="form-control form-control-sm">
      </div>
      <div class="col-auto align-self-end">
        <button class="btn btn-primary btn-sm" type="submit">Lọc</button>
      </div>
    </form>

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
      <div class="text-muted small">
        Tìm thấy <b><%= total.toLocaleString('vi-VN') %></b> log · Trang <%= page %>/<%= totalPages %>
      </div>
      <% if (status || country || device || ip) { %>
        <a class="btn btn-outline-secondary btn-sm" href="/short-links/<%= link.id %>/logs?start_date=<%= encodeURIComponent(startDateValue) %>&end_date=<%= encodeURIComponent(endDateValue) %>&limit=<%= limit %>">Xóa bộ lọc</a>
      <% } %>
    </div>

    <div class="table-responsive">
      <table class="table table-sm table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>Thời gian (VN)</th>
            <th>IP</th>
            <th>Quốc gia</th>
            <th>Thiết bị / OS</th>
            <th>Browser</th>
            <th>Trạng thái</th>
            <th>Referer</th>
            <th>Request URL</th>
          </tr>
        </thead>
        <tbody>
          <% if (!logs.length) { %><tr><td colspan="8" class="text-center text-muted">Không có log</td></tr><% } %>
          <% logs.forEach(log => { const meta = log.meta || {}; %>
            <tr>
              <td><%= new Date(log.created_at).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }) %></td>
              <td class="font-monospace"><%= log.ip || '-' %></td>
              <td><span class="badge bg-info text-dark"><%= log.country || '-' %></span></td>
              <td><%= log.device_type || 'pc' %> / <%= log.os_name || 'Unknown' %></td>
              <td><%= log.browser_name || 'Unknown' %></td>
              <td>
                <% if (log.action === 'short_redirect_confirmed') { %><span class="badge bg-success">Đã chuyển</span>
                <% } else if (log.action === 'short_link_open') { %><span class="badge bg-warning text-dark">Chưa xác nhận</span>
                <% } else { %><span class="badge bg-secondary">Dữ liệu cũ</span><% } %>
              </td>
              <td class="text-break small" style="max-width:240px;"><%= meta.ref || log.referer || '-' %></td>
              <td class="text-break small" style="max-width:320px;"><%= meta.url || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% if (totalPages > 1) { %>
      <nav class="mt-3" aria-label="Phân trang log">
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?<%= paginationQuery %>&page=<%= Math.max(1, page - 1) %>">Trước</a>
          </li>
          <li class="page-item disabled"><span class="page-link"><%= page %> / <%= totalPages %></span></li>
          <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="?<%= paginationQuery %>&page=<%= Math.min(totalPages, page + 1) %>">Sau</a>
          </li>
        </ul>
      </nav>
    <% } %>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
