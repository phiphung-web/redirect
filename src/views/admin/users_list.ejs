<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Người dùng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header', {
        user,
        active: 'users',
        backUrl: '/redirect',
        breadcrumb: [
            { label: 'Quản trị', url: '/users' },
            { label: 'Người dùng' }
        ]
    }) %>
    <div class="container mt-3" style="max-width: 1180px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h3 class="mb-1" data-help="Quản lý tài khoản được phép truy cập trang quản trị và phạm vi quyền của từng người.">Người dùng</h3>
                <div class="text-muted">Mỗi người dùng có tài khoản riêng để phân quyền và ghi nhật ký chính xác.</div>
            </div>
        </div>
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-bold"><span data-help="Tài khoản Inactive không thể đăng nhập nhưng lịch sử thao tác vẫn được giữ lại.">Danh sách</span></div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>#</th><th>Tài khoản</th><th>Role</th><th>Trạng thái</th><th>Ngày tạo</th><th class="text-end">Hành động</th></tr>
                    </thead>
                    <tbody>
                        <% users.forEach((u, idx) => { %>
                            <tr>
                                <td><%= idx + 1 %></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="rounded-circle bg-primary-subtle text-primary fw-bold d-inline-flex align-items-center justify-content-center" style="width:34px;height:34px;"><%= String(u.username || '?').slice(0, 1).toUpperCase() %></span>
                                        <div>
                                            <div class="fw-semibold"><%= u.username %></div>
                                            <% if (Number(u.id) === Number(user.id)) { %><small class="text-muted">Tài khoản của bạn</small><% } %>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge <%= u.role_name==='super_admin' ? 'bg-primary' : 'bg-secondary' %>"><%= u.role_name === 'super_admin' ? 'Super admin' : 'User' %></span></td>
                                <td><span class="badge <%= u.is_active ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' %>"><%= u.is_active ? 'Hoạt động' : 'Đã xóa' %></span></td>
                                <td><%= new Date(u.created_at).toLocaleString('vi-VN') %></td>
                                <td class="text-end">
                                    <a href="/users/view/<%= u.id %>" class="btn btn-sm btn-outline-primary"><%= u.is_active ? 'Chỉnh sửa' : 'Xem / khôi phục' %></a>
                                    <% if (currentUserRole==='super_admin' && u.is_active && Number(u.id) !== Number(user.id)) { %>
                                        <form action="/users/delete/<%= u.id %>" method="POST" class="d-inline" onsubmit="return confirm('Xóa user này? Tài khoản sẽ bị khóa, quyền chia sẻ bị thu hồi và tài nguyên sở hữu được chuyển về super admin.')">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <div class="fw-bold">Tạo người dùng</div>
                <small class="text-muted">Tài khoản mới mặc định có quyền User và chưa được truy cập domain nào.</small>
            </div>
            <form class="card-body" action="/users/create" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" data-help="Tên đăng nhập duy nhất. Nên dùng tên dễ nhận diện theo người vận hành.">Username</label>
                        <input type="text" name="username" class="form-control" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" data-help="Dùng mật khẩu riêng, tối thiểu 6 ký tự và không gửi qua kênh công khai.">Password</label>
                        <input type="password" name="password" class="form-control" minlength="6" autocomplete="new-password" required>
                    </div>
                </div>
                <div class="mt-3 text-end">
                    <button class="btn btn-primary px-4">Tạo user</button>
                </div>
            </form>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
