NODE_ENV=production
PRODUCT_NAME=LinkPilot
PRODUCT_SHORT_NAME=LP
PRODUCT_TAGLINE=Redirect & Campaign Control
PRODUCT_SUPPORT=

ADS_PORT=4101
ADMIN_PORT=4102
BIND_HOST=127.0.0.1
ADS_INSTANCES=4
ADS_MAX_MEMORY_RESTART=700M
TRUST_PROXY=1

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=redirect_pro
DB_USER=redirect_pro
DB_PASS=change_this_strong_password
DB_POOL_MAX=8
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

SESSION_NAME=linkpilot.sid
SESSION_SECRET=change_this_to_a_long_random_secret
SESSION_MAX_AGE_MS=86400000
SESSION_SECURE=auto
SESSION_STORE=postgres
SESSION_TABLE=user_sessions

CACHE_ENABLED=true
CACHE_TTL_MS=30000
CACHE_STALE_TTL_MS=300000
CACHE_MAX_ENTRIES=3000
TRAFFIC_BUFFER_ENABLED=true
TRAFFIC_BATCH_SIZE=100
TRAFFIC_FLUSH_MS=1000
TRAFFIC_QUEUE_MAX=5000
COUNTER_BUFFER_ENABLED=true
COUNTER_FLUSH_MS=2000

LOG_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/var/backups/linkpilot
