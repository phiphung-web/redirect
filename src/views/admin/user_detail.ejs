<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chi tiết User</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header', {
        user: viewer,
        active: selfView ? '' : 'users',
        backUrl: selfView ? '/' : '/users',
        breadcrumb: selfView ? [
            { label: 'Tài khoản' },
            { label: 'Hồ sơ' }
        ] : [
            { label: 'Quản trị', url: '/users' },
            { label: 'Người dùng', url: '/users' },
            { label: target.username }
        ]
    }) %>
    <div class="container" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0" data-help="Xem quyền, trạng thái và các tài nguyên liên quan đến tài khoản."><%= selfView ? 'Hồ sơ của tôi' : 'User: ' + target.username %></h3>
            <div></div>
        </div>
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <p><b>Role:</b> <span class="badge <%= target.role_name==='super_admin' ? 'bg-danger' : 'bg-secondary' %>"><%= target.role_name %></span></p>
                <p><b>Trạng thái:</b> <%= target.is_active ? 'Active' : 'Inactive' %></p>
                <p><b>Tạo lúc:</b> <%= new Date(target.created_at).toLocaleString('vi-VN') %></p>
                <p class="mb-0"><b>Telegram:</b>
                    <% if (target.telegram_chat_id) { %>
                        <span class="badge bg-success">Đã kết nối</span>
                        <%= target.telegram_username ? '@' + target.telegram_username : '' %>
                    <% } else { %>
                        <span class="badge bg-secondary">Chưa kết nối</span>
                    <% } %>
                    <% if (selfView) { %><a href="/account/telegram" class="btn btn-sm btn-outline-primary ms-2">Cài đặt Telegram</a><% } %>
                </p>
            </div>
        </div>
        <% if (!selfView && viewer.role_name === 'super_admin') { %>
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white fw-bold"><span data-help="Thay đổi có hiệu lực với lần kiểm tra quyền tiếp theo. Tránh tự hạ quyền tài khoản quản trị duy nhất.">Đổi role</span></div>
            <form class="card-body" action="/users/view/<%= target.id %>/role" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="row g-3 align-items-center">
                    <div class="col-md-8">
                        <select name="role_id" class="form-select">
                            <% roles.forEach(r => { %>
                                <option value="<%= r.id %>" <%= r.id === target.role_id ? 'selected' : '' %>><%= r.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-4 text-end">
                        <button class="btn btn-primary">Cập nhật</button>
                    </div>
                </div>
            </form>
        </div>
        <% } %>

        <% if (selfView) { %>
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white fw-bold">Đổi mật khẩu</div>
            <form class="card-body" action="/account/password" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% if (profileNotice) { %><div class="alert alert-info"><%= profileNotice %></div><% } %>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Mật khẩu hiện tại</label>
                        <input type="password" name="current_password" class="form-control" autocomplete="current-password" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mật khẩu mới</label>
                        <input type="password" name="new_password" class="form-control" minlength="6" autocomplete="new-password" required>
                        <div class="form-text">Tối thiểu 6 ký tự.</div>
                    </div>
                </div>
                <div class="text-end mt-3"><button class="btn btn-primary">Đổi mật khẩu</button></div>
            </form>
        </div>
        <% } %>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white fw-bold"><span data-help="Các domain tài khoản này đang được cấp quyền quản lý, gồm domain sở hữu và domain được chia sẻ.">Domain được truy cập</span></div>
                    <div class="card-body">
                        <% if(recentDomains.length===0){ %><div class="text-muted">Không có</div><% } %>
                        <ul class="list-group list-group-flush">
                            <% recentDomains.forEach(d => { %>
                                <li class="list-group-item">#<%= d.id %> - <%= d.domain_url %> <span class="badge <%= d.access_level === 'owner' ? 'bg-primary' : 'bg-secondary' %>"><%= d.access_level %></span><br><small class="text-muted"><%= new Date(d.created_at).toLocaleString('vi-VN') %></small></li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white fw-bold"><span data-help="Các campaign mới nhất được ghi nhận là do tài khoản này tạo.">Link gần đây</span></div>
                    <div class="card-body">
                        <% if(recentCamps.length===0){ %><div class="text-muted">Không có</div><% } %>
                        <ul class="list-group list-group-flush">
                            <% recentCamps.forEach(c => { %>
                                <li class="list-group-item">#<%= c.id %> - <%= c.name %> <br><small class="text-muted"><%= new Date(c.created_at).toLocaleString('vi-VN') %></small></li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
