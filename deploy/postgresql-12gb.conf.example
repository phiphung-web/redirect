# Balanced PostgreSQL 16 profile for a 6-vCPU / 12-GB RAM redirect server.
# Install as /etc/postgresql/16/main/conf.d/99-linkpilot-performance.conf.
shared_buffers = 2GB
effective_cache_size = 8GB
maintenance_work_mem = 512MB
work_mem = 8MB
max_connections = 80
checkpoint_completion_target = 0.9
wal_buffers = 16MB
min_wal_size = 1GB
max_wal_size = 4GB
random_page_cost = 1.1
effective_io_concurrency = 200
default_statistics_target = 100
