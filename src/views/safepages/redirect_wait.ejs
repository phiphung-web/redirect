<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex,nofollow">
  <meta http-equiv="refresh" content="<%= delaySeconds %>;url=<%= targetUrl %>">
  <title>Đang chuyển hướng</title>
  <style>
    :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    * { box-sizing: border-box; }
    body { margin: 0; min-height: 100vh; display: grid; place-items: center; padding: 24px; color: #132238; background: radial-gradient(circle at top, #eaf2ff 0, #f7f9fc 44%, #eef2f7 100%); }
    .wait-card { width: min(100%, 480px); padding: 42px 34px; text-align: center; background: rgba(255,255,255,.96); border: 1px solid rgba(18,68,145,.1); border-radius: 24px; box-shadow: 0 24px 70px rgba(23,55,94,.14); }
    .brand { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 26px; color: #1b5fd1; font-weight: 800; }
    .brand-mark { display: grid; place-items: center; width: 38px; height: 38px; border-radius: 12px; color: white; background: linear-gradient(135deg,#236ee8,#153f9a); }
    .spinner { width: 66px; height: 66px; margin: 0 auto 24px; border: 6px solid #dfe9f8; border-top-color: #236ee8; border-radius: 50%; animation: spin .85s linear infinite; }
    h1 { margin: 0 0 10px; font-size: clamp(24px,5vw,31px); }
    p { margin: 0; color: #607087; line-height: 1.65; }
    .countdown { color: #1b5fd1; font-weight: 800; font-variant-numeric: tabular-nums; }
    .manual { display: inline-block; margin-top: 24px; padding: 11px 18px; color: #1b5fd1; font-weight: 700; text-decoration: none; border: 1px solid #cbdcf6; border-radius: 12px; }
    .manual:hover { background: #edf4ff; }
    @keyframes spin { to { transform: rotate(360deg); } }
    @media (prefers-reduced-motion: reduce) { .spinner { animation-duration: 1.8s; } }
  </style>
</head>
<body>
  <main class="wait-card" id="redirectWait" data-target="<%= targetUrl %>" data-delay="<%= delaySeconds %>">
    <div class="brand"><span class="brand-mark"><%= product.shortName %></span><span><%= product.name %></span></div>
    <div class="spinner" aria-hidden="true"></div>
    <h1>Đang chuẩn bị liên kết</h1>
    <p>Bạn sẽ được chuyển hướng sau <span class="countdown" id="countdown"><%= delaySeconds %></span> giây.</p>
    <a class="manual" id="continueLink" href="<%= targetUrl %>" rel="nofollow">Tiếp tục ngay</a>
  </main>
  <script>
    (() => {
      const root = document.getElementById("redirectWait");
      const countdown = document.getElementById("countdown");
      const target = root.dataset.target;
      const delay = Math.max(1, Number.parseInt(root.dataset.delay, 10) || 3);
      const deadline = Date.now() + delay * 1000;
      const timer = window.setInterval(() => {
        const remaining = Math.max(0, Math.ceil((deadline - Date.now()) / 1000));
        countdown.textContent = String(remaining);
        if (remaining === 0) window.clearInterval(timer);
      }, 200);
      window.setTimeout(() => window.location.replace(target), delay * 1000);
    })();
  </script>
</body>
</html>
