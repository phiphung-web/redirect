<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Báo cáo link tự chuyển - <%= link.title || link.code %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .report-filter-field { min-width: 150px; }
    .report-filter-field .form-label { margin-bottom: 4px; color: #667085; font-size: .78rem; font-weight: 700; }
  </style>
</head>
<body class="bg-light">
  <%- include('../partials/header', {
    user,
    active: 'short-links',
    backUrl: '/domains/' + link.domain_id,
    breadcrumb: [
      { label: link.domain_url, url: '/domains/' + link.domain_id },
      { label: 'Link tự chuyển' },
      { label: link.title || link.code },
      { label: 'Báo cáo' }
    ]
  }) %>

  <div class="container-xxl py-3">
    <div class="card shadow-sm mb-3">
      <div class="card-body d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
          <div class="text-muted small">Link tự chuyển sau thời gian chờ</div>
          <h4 class="mb-1" data-help="Báo cáo của link chuyển hướng này, tách biệt với báo cáo campaign."><%= link.title || link.code %></h4>
          <div class="input-group input-group-sm" style="max-width:520px;">
            <input type="text" class="form-control bg-white text-primary fw-bold" value="https://<%= link.domain_url %>/s/<%= link.code %>" readonly id="shortReportUrl">
            <button class="btn btn-outline-primary" type="button" onclick="copyShortReportUrl()"><i class="fa-solid fa-copy"></i></button>
          </div>
          <div class="text-muted small mt-1">Khoảng: <%= rangeLabel %> · Nhóm theo: <%= bucketType %></div>
        </div>
        <form class="d-flex flex-wrap align-items-end gap-2" method="get">
          <div class="report-filter-field">
            <label class="form-label" for="presetSelect" data-help="Chọn khoảng thời gian dùng cho toàn bộ số liệu, bảng phân bổ và log bên dưới.">Mốc thời gian</label>
            <select class="form-select" id="presetSelect" name="preset" onchange="toggleCustomPreset(this.value)">
              <option value="today" <%= preset === 'today' ? 'selected' : '' %>>Hôm nay</option>
              <option value="this_week" <%= preset === 'this_week' ? 'selected' : '' %>>Tuần này</option>
              <option value="this_month" <%= preset === 'this_month' ? 'selected' : '' %>>Tháng này</option>
              <option value="this_year" <%= preset === 'this_year' ? 'selected' : '' %>>Năm nay</option>
              <option value="all" <%= preset === 'all' ? 'selected' : '' %>>Tất cả</option>
              <option value="custom" <%= preset === 'custom' ? 'selected' : '' %>>Tùy chọn</option>
            </select>
          </div>
          <div class="report-filter-field custom-range d-none">
            <label class="form-label" for="startDate">Từ ngày</label>
            <input type="date" class="form-control" id="startDate" name="start_date" value="<%= start ? new Date(start).toISOString().slice(0,10) : '' %>">
          </div>
          <div class="report-filter-field custom-range d-none">
            <label class="form-label" for="endDate">Đến ngày</label>
            <input type="date" class="form-control" id="endDate" name="end_date" value="<%= end ? new Date(end).toISOString().slice(0,10) : '' %>">
          </div>
          <button class="btn btn-primary" type="submit">Lọc</button>
          <a class="btn btn-outline-primary" href="/short-links/<%= link.id %>/report/export">CSV</a>
        </form>
      </div>
    </div>

    <div class="alert alert-info py-2 small">
      <i class="fa-solid fa-circle-info me-1"></i>
      Số liệu có thể thiếu một phần nếu người dùng đóng trang sớm, mất mạng, tắt JavaScript hoặc trình duyệt chặn yêu cầu xác nhận.
    </div>

    <% if (lifetime.legacy_unverified > 0) { %>
      <div class="alert alert-secondary py-2 small"><%= lifetime.legacy_unverified %> lượt dữ liệu cũ được ghi trước cơ chế xác nhận, không tính vào số đã chuyển hướng.</div>
    <% } %>

    <div class="row g-3">
      <div class="col-md-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small" data-help="Số lần Safe Page của link được tải. Người dùng có thể đóng trang trước khi chuyển hướng.">Mở link</div>
            <div class="display-6 fw-bold"><%= summary.opened || 0 %></div>
            <div class="text-muted small">So với kỳ trước: <%= delta.opened >= 0 ? '+' : '' %><%= delta.opened %></div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small" data-help="Trình duyệt đã gửi xác nhận sau khi hết thời gian chờ, ngay trước lệnh điều hướng.">Đã kích hoạt chuyển hướng</div>
            <div class="display-6 fw-bold text-success"><%= summary.confirmed || 0 %></div>
            <div class="text-muted small">Toàn thời gian: <%= lifetime.confirmed || 0 %></div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small" data-help="Đã mở link nhưng chưa nhận được xác nhận chuyển hướng; có thể đã thoát sớm, tắt JavaScript hoặc mất mạng.">Chưa xác nhận</div>
            <div class="display-6 fw-bold text-warning"><%= summary.unconfirmed || 0 %></div>
            <div class="text-muted small">Toàn thời gian: <%= lifetime.unconfirmed || 0 %></div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small">IP đã chuyển hướng</div>
            <div class="display-6 fw-bold"><%= summary.unique_ips || 0 %></div>
            <div class="text-muted small">Kỳ trước: <%= previous.unique_ips || 0 %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-3">
      <div class="col-lg-8">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <b><i class="fa-solid fa-chart-line me-2"></i>Chuyển hướng đã xác nhận theo thời gian</b>
            <span class="text-muted small"><%= presetLabel %></span>
          </div>
          <div class="card-body">
            <canvas id="shortTrafficChart" height="120"></canvas>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="card shadow-sm mb-3">
          <div class="card-header bg-white"><b data-help="Phân bổ các lượt chuyển hướng đã xác nhận theo quốc gia suy ra từ địa chỉ IP.">Top quốc gia</b></div>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <tbody>
                <% if (!countryStats.length) { %><tr><td class="text-center text-muted py-3">Chưa có dữ liệu</td></tr><% } %>
                <% countryStats.forEach(row => { %>
                  <tr><td><%= row.country || 'N/A' %></td><td class="text-end fw-bold"><%= row.hits %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card shadow-sm">
          <div class="card-header bg-white"><b data-help="Loại thiết bị được suy ra từ User-Agent và có thể không chính xác với một số trình duyệt riêng tư.">Thiết bị</b></div>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <tbody>
                <% if (!deviceStats.length) { %><tr><td class="text-center text-muted py-3">Chưa có dữ liệu</td></tr><% } %>
                <% deviceStats.forEach(row => { %>
                  <tr><td><%= row.device_type || 'pc' %></td><td class="text-end fw-bold"><%= row.hits %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mt-3">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <b data-help="Các lượt mở link gần nhất cùng nguồn giới thiệu, thiết bị và URL request.">Log mới</b>
        <a class="btn btn-link btn-sm" href="/short-links/<%= link.id %>/logs">Xem tất cả</a>
      </div>
      <div class="table-responsive p-3">
        <table class="table table-sm table-striped table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th>Thời gian (VN)</th>
              <th>IP</th>
              <th>Quốc gia</th>
              <th>Thiết bị / OS</th>
              <th>Browser</th>
              <th>Trạng thái</th>
              <th>Request URL</th>
            </tr>
          </thead>
          <tbody>
            <% if (!logs.length) { %><tr><td colspan="7" class="text-center text-muted">Không có log</td></tr><% } %>
            <% logs.forEach(log => { const meta = log.meta || {}; %>
              <tr>
                <td><%= new Date(log.created_at).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }) %></td>
                <td class="font-monospace"><%= log.ip || '-' %></td>
                <td><span class="badge bg-info text-dark"><%= log.country || '-' %></span></td>
                <td><%= log.device_type || 'pc' %> / <%= log.os_name || 'Unknown' %></td>
                <td><%= log.browser_name || 'Unknown' %></td>
                <td>
                  <% if (log.action === 'short_redirect_confirmed') { %><span class="badge bg-success">Đã chuyển</span>
                  <% } else if (log.action === 'short_link_open') { %><span class="badge bg-warning text-dark">Chưa xác nhận</span>
                  <% } else { %><span class="badge bg-secondary">Dữ liệu cũ</span><% } %>
                </td>
                <td class="text-break small"><%= meta.url || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    function copyShortReportUrl() {
      const el = document.getElementById('shortReportUrl');
      el.select();
      document.execCommand('copy');
      alert('Đã copy');
    }
    function todayStr() {
      const now = new Date();
      const tzOffset = now.getTimezoneOffset() * 60000;
      return new Date(now.getTime() - tzOffset).toISOString().slice(0, 10);
    }
    function toggleCustomPreset(val) {
      const isCustom = val === 'custom';
      document.querySelectorAll('.custom-range').forEach(el => el.classList.toggle('d-none', !isCustom));
      if (isCustom) {
        if (!document.getElementById('startDate').value) document.getElementById('startDate').value = todayStr();
        if (!document.getElementById('endDate').value) document.getElementById('endDate').value = todayStr();
      }
    }
    toggleCustomPreset('<%= preset %>');

    const statsData = <%- JSON.stringify(stats || []) %>;
    const bucketType = '<%= bucketType %>';
    const formatLabel = (raw) => {
      const d = new Date(raw);
      if (bucketType === 'hour') return d.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Ho_Chi_Minh' });
      if (bucketType === 'month') return d.toLocaleDateString('vi-VN', { month: 'short', year: 'numeric', timeZone: 'Asia/Ho_Chi_Minh' });
      return d.toLocaleDateString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' });
    };
    const ctx = document.getElementById('shortTrafficChart');
    if (ctx && statsData.length) {
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: statsData.map(row => formatLabel(row.bucket)),
          datasets: [
            { label: 'Đã kích hoạt chuyển hướng', data: statsData.map(row => Number(row.confirmed || 0)), borderColor: '#198754', backgroundColor: 'rgba(25,135,84,0.12)', tension: 0.3 }
          ]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
      });
    }
  </script>
  <%- include('../partials/footer') %>
</body>
</html>
