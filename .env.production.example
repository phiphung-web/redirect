NODE_ENV=production
PRODUCT_NAME=LinkPilot
PRODUCT_SHORT_NAME=LP
PRODUCT_TAGLINE=Redirect & Campaign Control
PRODUCT_SUPPORT=

ADS_PORT=4101
ADMIN_PORT=4102
BIND_HOST=127.0.0.1
ADS_INSTANCES=auto
ADS_MAX_MEMORY_RESTART=700M
TRUST_PROXY=1
EDGE_COUNTRY_HEADER=cf-ipcountry

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=redirect_pro
DB_USER=redirect_pro
DB_PASS=change_this_strong_password
DB_POOL_MAX=8
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

SESSION_NAME=linkpilot.sid
SESSION_SECRET=change_this_to_a_long_random_secret
SESSION_MAX_AGE_MS=86400000
SESSION_SECURE=auto
SESSION_STORE=postgres
SESSION_TABLE=user_sessions

CACHE_ENABLED=true
CACHE_TTL_MS=30000
CACHE_STALE_TTL_MS=300000
CACHE_MAX_ENTRIES=3000
TRAFFIC_BUFFER_ENABLED=true
TRAFFIC_BATCH_SIZE=100
TRAFFIC_FLUSH_MS=1000
TRAFFIC_QUEUE_MAX=5000
COUNTER_BUFFER_ENABLED=true
COUNTER_FLUSH_MS=2000

LOG_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/var/backups/linkpilot

# Automatic per-domain TLS. The provision command is installed by
# deploy/install-auto-ssl.sh and validates every hostname again before Certbot.
AUTO_SSL_ENABLED=false
SSL_PROVISION_COMMAND=/usr/local/sbin/redirect-pro-provision-domain
SSL_PROVISION_TIMEOUT_MS=180000
SSL_RETRY_INTERVAL_MS=300000
SSL_MAX_ATTEMPTS=5
CERTBOT_EMAIL=admin@example.com
LETSENCRYPT_AGREE_TOS=false

# One shared bot; every product user links a separate private Telegram chat.
# Keep the token only in .env. TELEGRAM_ADMIN_CHAT_ID is an optional fallback
# for server-wide alerts when the database is unavailable.
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_REQUEST_TIMEOUT_MS=10000
TELEGRAM_ALERT_COOLDOWN_MINUTES=15

MONITOR_EXPECTED_IPV4=
MONITOR_DISK_PATH=/opt/linkpilot
MONITOR_DISK_USAGE_PERCENT=85
MONITOR_MEMORY_USAGE_PERCENT=90
MONITOR_BACKUP_MAX_AGE_HOURS=30
MONITOR_SSL_EXPIRY_WARNING_DAYS=14
MONITOR_ALERT_REPEAT_MINUTES=360
MONITOR_STATE_FILE=/var/lib/linkpilot/monitor-state.json
MONITOR_ADMIN_HEALTH_URL=http://127.0.0.1:4102/healthz
MONITOR_ADS_HEALTH_URL=http://127.0.0.1:4101/healthz

# Private JSON-lines request audit. Never expose this file through the UI.
AUDIT_FILE_PATH=/var/log/linkpilot/audit.log
AUDIT_FILE_MAX_MB=20
AUDIT_RETENTION_DAYS=7
