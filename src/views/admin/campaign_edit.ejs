            const oldRules = <%- JSON.stringify(camp.rules || []) %>;
            const oldCountryFilter = <%- JSON.stringify(camp.filters?.countries || []) %>;
            const SYSTEM_RULE_KEYS = new Set(['fbclid', 'fbcid']);

            $(document).ready(function () {
                const select = $('#countrySelect');
                for (let [code, name] of Object.entries(ALL_COUNTRIES)) {
                    select.append(new Option(`${name} (${code})`, code));
                }
                select.select2().val(oldCountryFilter).trigger('change');
                oldRules.forEach(r => addNewRule(r.key, r.operator, r.value, r.copyValue));
            });

            function addNewRule(key = '', op = 'exists', val = '', copyValue = '') {
                const isSystemRule = SYSTEM_RULE_KEYS.has(String(key).trim().toLowerCase());
                const row = $(`
                <div class="row g-2 mb-2 rule-row align-items-center">
                    <div class="col-md-4"><input type="text" class="form-control form-control-sm rule-key" placeholder="Key"></div>
                    <div class="col-md-3"><select class="form-select form-select-sm rule-op" onchange="toggleVal(this)"><option value="exists">Tồn tại</option><option value="equals">Bằng (=)</option></select></div>
                    <div class="col-md-4"><input type="text" class="form-control form-control-sm rule-val" placeholder="Giá trị cần khớp"></div>
                    <div class="col-md-1"><button type="button" class="btn btn-sm text-danger" onclick="this.closest('.rule-row').remove()">x</button></div>
                    <input type="hidden" class="rule-copy-val">
                </div>`);
                row.find('.rule-key').val(key);
                row.find('.rule-op').val(op === 'equals' ? 'equals' : 'exists');
                row.find('.rule-val').val(val);
                row.find('.rule-copy-val').val(copyValue);
                if (isSystemRule) {
                    row.attr('data-system-rule', 'true');
                    row.find('.rule-key').prop('readonly', true);
                    row.find('.rule-op').val('exists').prop('disabled', true);
                    row.find('.rule-val').val('').prop('disabled', true).prop('required', false).attr('placeholder', 'Không cần giá trị');
                    row.find('.rule-copy-val').val('').prop('disabled', true);
                    row.find('button').attr('title', 'Xóa kiểm tra fbclid');
                }
                $('#rules-wrapper').append(row);
                toggleVal(row.find('.rule-op')[0]);
            }

            function toggleVal(sel) {
                const inp = sel.closest('.rule-row').querySelector('.rule-val');
                const copyInp = sel.closest('.rule-row').querySelector('.rule-copy-val');
                const isSystemRule = sel.closest('.rule-row').dataset.systemRule === 'true';
                if (isSystemRule) {
                    sel.value = 'exists';
                    inp.value = '';
                    inp.disabled = true;
                    inp.required = false;
                    copyInp.value = '';
                    copyInp.disabled = true;
                    return;
                }
                inp.disabled = (sel.value === 'exists');
                inp.required = (sel.value === 'equals');
                copyInp.disabled = (sel.value === 'equals');
                if (inp.disabled) inp.value = '';
                if (sel.value === 'equals') copyInp.value = inp.value;
            }

            function collectRules() {
                const rules = [];
                $('.rule-row').each(function () {
                    let k = $(this).find('.rule-key').val();
                    let o = $(this).find('.rule-op').val();
                    let v = $(this).find('.rule-val').val();
                    let copyValue = o === 'exists' ? $(this).find('.rule-copy-val').val() : '';
                    const normalizedKey = String(k || '').trim().toLowerCase();
                    if (normalizedKey === 'fbclid') {
                        rules.push({ key: 'fbclid', operator: 'exists', value: '' });
                    } else if (k && normalizedKey !== 'fbcid') {
                        rules.push({ key: k, operator: o, value: v, ...(copyValue ? { copyValue } : {}) });
                    }
                });
                return rules;
            }

            $('#editForm').on('submit', function () {
                $('#rules_json').val(JSON.stringify(collectRules()));
            });
        </script>
