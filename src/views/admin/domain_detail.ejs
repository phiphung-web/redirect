            const RULE_TEMPLATES = {
                fb_custom: [
                    { key: 'fbclid', operator: 'exists', value: '' },
                    { key: 'utm_source', operator: 'equals', value: '' },
                    { key: 'utm_medium', operator: 'equals', value: '' },
                    { key: 'utm_campaign', operator: 'equals', value: '' },
                    { key: 'utm_content', operator: 'equals', value: '' }
                ]
            };
            const COPY_EXCLUDED_RULE_KEYS = new Set(['fbclid', 'fbcid']);

            function addNewRule(key = '', op = 'exists', val = '', copyValue = '') {
                const wrapper = document.getElementById('rules-wrapper');
                const row = document.createElement('div');
                const isSystemRule = COPY_EXCLUDED_RULE_KEYS.has(String(key).trim().toLowerCase());
                row.className = 'row g-2 mb-2 rule-row align-items-center';
                row.dataset.systemRule = isSystemRule ? 'true' : 'false';
                row.innerHTML = '<div class="col-md-4"></div><div class="col-md-3"></div><div class="col-md-4"></div><div class="col-md-1"></div>';

                const keyInput = document.createElement('input');
                keyInput.type = 'text';
                keyInput.className = 'form-control form-control-sm rule-key';
                keyInput.placeholder = 'Key (vd: utm_source)';
                keyInput.value = String(key || '');

                const operator = document.createElement('select');
                operator.className = 'form-select form-select-sm rule-op';
                operator.innerHTML = '<option value="exists">Tồn tại</option><option value="equals">Bằng (=)</option>';
                operator.value = op === 'equals' ? 'equals' : 'exists';

                const valueInput = document.createElement('input');
                valueInput.type = 'text';
                valueInput.className = 'form-control form-control-sm rule-val';
                valueInput.placeholder = 'Giá trị';
                valueInput.value = String(val || '');
                valueInput.disabled = operator.value === 'exists';
                valueInput.required = operator.value === 'equals';

                const copyValueInput = document.createElement('input');
                copyValueInput.type = 'hidden';
                copyValueInput.className = 'rule-copy-val';
                copyValueInput.value = String(copyValue || '');

                const remove = document.createElement('button');
                remove.type = 'button';
                remove.className = 'btn btn-sm text-danger';
                remove.setAttribute('aria-label', 'Xóa rule');
                remove.textContent = '×';

                if (isSystemRule) {
                    keyInput.readOnly = true;
                    operator.value = 'exists';
                    operator.disabled = true;
                    valueInput.value = '';
                    valueInput.disabled = true;
                    valueInput.required = false;
                    valueInput.placeholder = 'Không cần giá trị';
                    copyValueInput.value = '';
                    copyValueInput.disabled = true;
                    remove.setAttribute('aria-label', 'Xóa rule fbclid');
                    remove.title = 'Xóa kiểm tra fbclid';
                }

                row.children[0].appendChild(keyInput);
                row.children[1].appendChild(operator);
                row.children[2].appendChild(valueInput);
                row.children[3].appendChild(remove);
                row.appendChild(copyValueInput);
                wrapper.appendChild(row);

                const refreshRow = () => {
                    const isEquals = operator.value === 'equals';
                    const isExcluded = row.dataset.systemRule === 'true';
                    if (isExcluded) operator.value = 'exists';
                    valueInput.disabled = !isEquals;
                    valueInput.required = isEquals && !isExcluded;
                    copyValueInput.disabled = isEquals || isExcluded;
                    if (isEquals) copyValueInput.value = valueInput.value;
                    if (isExcluded) {
                        valueInput.value = '';
                        valueInput.disabled = true;
                        copyValueInput.value = '';
                    }
                    updateRulesQueryString();
                };

                keyInput.addEventListener('input', () => {
                    refreshRow();
                });
                valueInput.addEventListener('input', () => {
                    if (operator.value === 'equals') copyValueInput.value = valueInput.value;
                    updateRulesQueryString();
                });
                operator.addEventListener('change', () => {
                    if (operator.value === 'exists') valueInput.value = '';
                    refreshRow();
                });
                copyValueInput.addEventListener('input', () => {
                    updateRulesQueryString();
                });
                remove.addEventListener('click', () => {
                    row.remove();
                    updateRulesQueryString();
                });
                refreshRow();
            }

            function addTemplate(type) {
                const wrapper = document.getElementById('rules-wrapper');
                wrapper.replaceChildren();
                (RULE_TEMPLATES[type] || []).forEach((rule) => addNewRule(rule.key, rule.operator, rule.value, rule.copyValue));
                updateRulesQueryString();
            }

            function collectRules() {
                const configurableRules = Array.from(document.querySelectorAll('#rules-wrapper .rule-row')).flatMap((row) => {
                    const key = row.querySelector('.rule-key').value.trim();
                    if (!key) return [];
                    if (key.toLowerCase() === 'fbclid') {
                        return [{ key: 'fbclid', operator: 'exists', value: '' }];
                    }
                    if (key.toLowerCase() === 'fbcid') return [];
                    const operator = row.querySelector('.rule-op').value;
                    const copyValue = operator === 'exists'
                        ? row.querySelector('.rule-copy-val').value.trim()
                        : '';
                    return [{
                        key,
                        operator,
                        value: row.querySelector('.rule-val').value.trim(),
                        ...(copyValue ? { copyValue } : {})
                    }];
                });
                return configurableRules;
            }

            function encodeUrlParameterValue(value) {
                return encodeURIComponent(value).replaceAll('%7B', '{').replaceAll('%7D', '}');
            }

            function buildRulesQueryString() {
                return Array.from(document.querySelectorAll('#rules-wrapper .rule-row')).flatMap((row) => {
                    const key = row.querySelector('.rule-key').value.trim();
                    if (!key) return [];
                    if (COPY_EXCLUDED_RULE_KEYS.has(key.toLowerCase())) return [];
                    const operator = row.querySelector('.rule-op').value;
                    const value = operator === 'equals'
                        ? row.querySelector('.rule-val').value.trim()
                        : row.querySelector('.rule-copy-val').value.trim();
                    if (!value) return [];
                    return [`${encodeURIComponent(key)}=${encodeUrlParameterValue(value)}`];
                }).join('&');
            }

            function updateRulesQueryString() {
                const input = document.getElementById('rulesQueryString');
                const button = document.getElementById('copyGeneratedParamsButton');
                const status = document.getElementById('copyGeneratedParamsStatus');
                if (input) input.value = buildRulesQueryString();
                if (button) button.disabled = !input?.value;
                if (status && !status.classList.contains('text-success')) {
                    status.textContent = '';
                }
            }

            function setLinkType(type) {
                const isConditional = type === 'conditional';
                const isDelayed = type === 'delayed';
                if (!isConditional && !isDelayed) return;

                const form = document.getElementById('createForm');
                document.getElementById('linkType').value = type;
                document.getElementById('linkConfiguration').hidden = false;
                document.getElementById('conditionalFields').hidden = !isConditional;
                document.getElementById('delayedFields').hidden = !isDelayed;
                form.action = isConditional ? '/campaigns/create' : '/short-links/create';

                document.querySelectorAll('[data-flow-field]').forEach((field) => {
                    field.disabled = field.dataset.flowField !== type;
                });
                document.querySelector('[name="redirect_delay_seconds"]').required = isDelayed;
                document.querySelectorAll('[data-link-type]').forEach((card) => {
                    card.classList.toggle('is-active', card.dataset.linkType === type);
                    card.setAttribute('aria-pressed', card.dataset.linkType === type ? 'true' : 'false');
                });

                if (isConditional && !document.querySelector('#rules-wrapper .rule-row')) {
                    addTemplate('fb_custom');
                }

                const submit = document.getElementById('createLinkSubmit');
                submit.disabled = false;
                submit.textContent = isConditional ? 'Tạo link kiểm tra tham số' : 'Tạo link tự chuyển';
            }

            async function copyGeneratedParams() {
                const el = document.getElementById('rulesQueryString');
                const button = document.getElementById('copyGeneratedParamsButton');
                const status = document.getElementById('copyGeneratedParamsStatus');
                if (!el || !el.value || button?.disabled) {
                    if (status) {
                        status.className = 'text-danger fw-semibold';
                        status.textContent = 'Chưa có thông số để sao chép.';
                    }
                    return;
                }
                try {
                    await navigator.clipboard.writeText(el.value);
                } catch (_) {
                    el.select();
                    document.execCommand('copy');
                }
                if (status) {
                    status.className = 'text-success fw-semibold';
                    status.textContent = 'Đã sao chép — dán vào mục Thông số URL của quảng cáo.';
                }
                if (button) {
                    const original = button.innerHTML;
                    button.innerHTML = '<i class="fas fa-check me-1"></i>Đã sao chép';
                    button.classList.replace('btn-primary', 'btn-success');
                    window.setTimeout(() => {
                        button.innerHTML = original;
                        button.classList.replace('btn-success', 'btn-primary');
                    }, 1800);
                }
            }

            function checkDNS(id) {
                const token = document.getElementById('csrfToken').value;
                fetch(`/domains/${id}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `_csrf=${encodeURIComponent(token)}`
                }).then(r => r.json()).then(d => { alert(d.msg); location.reload(); });
            }

            function copyLink(id) {
                const el = document.getElementById(id);
                el.select();
                document.execCommand("copy");
                alert("Đã copy");
            }

            function onCopySelect() {
                const id = document.getElementById('copyFromSelect').value;
                document.getElementById('copy_from_id').value = id;
                if (!id) {
                    document.getElementById('configPreview').innerText = 'Chọn link để xem cấu hình.';
                    return;
                }
                fetch(`/api/campaigns/${id}/config`).then(r => r.json()).then(cfg => {
                    const rules = (cfg.rules || []).map(r => `${r.key} (${r.operator}${r.value ? ':' + r.value : ''})`).join(', ');
                    const countries = (cfg.filters && cfg.filters.countries && cfg.filters.countries.length) ? cfg.filters.countries.join(', ') : 'All';
                    document.getElementById('configPreview').innerText = `Rules: ${rules || 'Mặc định'} | Countries: ${countries}`;
                    document.getElementById('rules-wrapper').replaceChildren();
                    (cfg.rules || []).forEach(r => addNewRule(r.key, r.operator, r.value, r.copyValue));
                    const selectedCountries = cfg.filters?.countries || [];
                    const countrySelect = document.getElementById('countrySelect');
                    Array.from(countrySelect.options).forEach((option) => {
                        option.selected = selectedCountries.includes(option.value);
                    });
                    if (window.jQuery && jQuery.fn.select2) jQuery(countrySelect).trigger('change');
                    updateRulesQueryString();
                }).catch(() => document.getElementById('configPreview').innerText = 'Không tải được cấu hình');
            }

            document.addEventListener('DOMContentLoaded', function () {
                const countrySelect = document.getElementById('countrySelect');
                Object.entries(ALL_COUNTRIES).forEach(([code, name]) => {
                    countrySelect.appendChild(new Option(`${name} (${code})`, code));
                });
                if (window.jQuery && jQuery.fn.select2) {
                    jQuery(countrySelect).select2({ placeholder: 'Chọn quốc gia...', dropdownParent: jQuery('#addLinkModal') });
                }

                document.querySelectorAll('[data-link-type]').forEach((button) => {
                    button.addEventListener('click', () => setLinkType(button.dataset.linkType));
                });
                document.querySelectorAll('[data-create-link-type]').forEach((button) => {
                    button.addEventListener('click', () => setLinkType(button.dataset.createLinkType));
                });
                document.querySelectorAll('[data-rule-template]').forEach((button) => {
                    button.addEventListener('click', () => addTemplate(button.dataset.ruleTemplate));
                });
                document.getElementById('addRuleButton').addEventListener('click', () => addNewRule());
                document.getElementById('createForm').addEventListener('submit', function (event) {
                    const type = document.getElementById('linkType').value;
                    if (!type) {
                        event.preventDefault();
                        return;
                    }
                    document.getElementById('rules_json').value = type === 'conditional'
                        ? JSON.stringify(collectRules())
                        : '[]';
                });
                updateRulesQueryString();
            });
        </script>
