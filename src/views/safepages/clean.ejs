<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="robots" content="noindex,nofollow,noarchive">
  <%- include('../partials/safe_redirect_head') %>
  <title>Repair &amp; Maintenance Services</title>
  <style>
    :root {
      color-scheme: light;
      --navy: #0f2747;
      --blue: #1268b3;
      --hero: #d1e3ff;
      --text: #132238;
      --muted: #5f6f82;
      --surface: #ffffff;
      --soft: #f5f8fc;
      --line: #dfe7f1;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      color: var(--text);
      background: var(--surface);
      font-family: Lato, Arial, Helvetica, sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    img { display: block; max-width: 100%; }
    .wrap { width: min(1120px, calc(100% - 36px)); margin: 0 auto; }
    .hero { overflow: hidden; background: var(--hero); }
    .hero-grid {
      min-height: 610px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, .82fr);
      align-items: center;
      gap: 56px;
    }
    .kicker {
      margin: 0 0 14px;
      color: var(--blue);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: .14em;
      text-transform: uppercase;
    }
    h1, h2, h3, p { margin-top: 0; }
    h1 {
      max-width: 660px;
      margin-bottom: 22px;
      color: var(--navy);
      font-size: clamp(46px, 6.2vw, 78px);
      line-height: .98;
      letter-spacing: -.045em;
    }
    .lead {
      max-width: 650px;
      margin-bottom: 30px;
      color: #445a74;
      font-size: 18px;
      line-height: 1.75;
    }
    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      padding: 0 24px;
      border: 2px solid var(--navy);
      border-radius: 4px;
      color: #fff;
      background: var(--navy);
      font-weight: 800;
      text-decoration: none;
      transition: transform .2s ease, background .2s ease;
    }
    .button:hover { transform: translateY(-2px); background: #173b68; }
    .hero-visual { align-self: end; display: flex; justify-content: center; }
    .hero-visual img { width: min(100%, 485px); max-height: 610px; object-fit: contain; object-position: bottom; }
    .section { padding: 88px 0; }
    .about-grid {
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(360px, 1.1fr);
      gap: 72px;
      align-items: center;
    }
    h2 { margin-bottom: 18px; color: var(--navy); font-size: clamp(34px, 4vw, 52px); line-height: 1.05; }
    .copy { color: var(--muted); font-size: 17px; line-height: 1.8; }
    .about-image { overflow: hidden; border-radius: 5px; box-shadow: 0 22px 55px rgba(15,39,71,.15); }
    .about-image img { width: 100%; aspect-ratio: 700 / 485; object-fit: cover; }
    .services { padding: 76px 0; background: var(--soft); }
    .section-head { max-width: 680px; margin-bottom: 34px; }
    .service-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .service-card { padding: 28px; border: 1px solid var(--line); border-radius: 6px; background: #fff; }
    .service-number { margin-bottom: 20px; color: var(--blue); font-size: 14px; font-weight: 900; }
    .service-card h3 { margin-bottom: 10px; color: var(--navy); font-size: 20px; }
    .service-card p { margin-bottom: 0; color: var(--muted); line-height: 1.65; }
    .contact { padding: 86px 0; }
    .contact-grid { display: grid; grid-template-columns: 1fr .8fr; gap: 64px; align-items: start; }
    .contact-form { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .field { display: grid; gap: 7px; }
    .field.full { grid-column: 1 / -1; }
    label { color: var(--navy); font-size: 14px; font-weight: 800; }
    input, textarea {
      width: 100%;
      border: 1px solid #cfd9e6;
      border-radius: 4px;
      padding: 13px 14px;
      color: var(--text);
      background: #fff;
      font: inherit;
      outline: none;
    }
    input:focus, textarea:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(18,104,179,.12); }
    textarea { min-height: 128px; resize: vertical; }
    .contact-card { padding: 34px; color: #dbe8f7; border-radius: 6px; background: var(--navy); }
    .contact-card h3 { margin-bottom: 22px; color: #fff; font-size: 25px; }
    .contact-item { padding: 17px 0; border-top: 1px solid rgba(255,255,255,.14); }
    .contact-item:first-of-type { padding-top: 0; border-top: 0; }
    .contact-item strong { display: block; margin-bottom: 5px; color: #fff; }
    .contact-item span { color: #b9cce2; line-height: 1.5; }
    .form-note { display: none; grid-column: 1 / -1; margin: 0; color: #167849; font-weight: 700; }
    footer { padding: 28px 0; color: #b9cce2; background: #0b1c33; text-align: center; font-size: 14px; }
    @media (max-width: 820px) {
      .wrap { width: min(100% - 28px, 680px); }
      .hero-grid { min-height: auto; grid-template-columns: 1fr; gap: 22px; padding-top: 64px; }
      h1 { font-size: clamp(43px, 13vw, 64px); }
      .lead { font-size: 16px; }
      .hero-visual img { max-height: 510px; }
      .section { padding: 64px 0; }
      .about-grid, .contact-grid { grid-template-columns: 1fr; gap: 38px; }
      .about-image { order: -1; }
      .service-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 520px) {
      .hero-grid { padding-top: 48px; }
      .hero-visual img { width: 88%; }
      .services, .contact { padding: 58px 0; }
      .contact-form { grid-template-columns: 1fr; }
      .field.full { grid-column: auto; }
      .button { width: 100%; }
    }
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <div class="wrap hero-grid">
        <div>
          <p class="kicker">Trusted local professionals</p>
          <h1>Repair and Maintenance Services</h1>
          <p class="lead">Practical repair solutions for homes and small businesses. Our experienced team handles everyday maintenance with clear communication, careful workmanship and dependable service.</p>
          <a class="button" href="#contact">Request a Service</a>
        </div>
        <div class="hero-visual">
          <img src="/assets/images/safe-repair-hero.png" width="485" height="689" alt="Professional repair technician">
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap about-grid">
        <div>
          <p class="kicker">About us</p>
          <h2>Reliable help for everyday repairs</h2>
          <p class="copy">We provide straightforward maintenance services designed around your schedule. From small household fixes to routine property care, every job is approached with attention to detail and respect for your space.</p>
        </div>
        <div class="about-image">
          <img src="/assets/images/safe-repair-about.jpg" width="700" height="485" loading="lazy" alt="Maintenance specialist at work">
        </div>
      </div>
    </section>

    <section class="services">
      <div class="wrap">
        <div class="section-head">
          <p class="kicker">What we do</p>
          <h2>Services built around your property</h2>
        </div>
        <div class="service-grid">
          <article class="service-card"><div class="service-number">01</div><h3>Home Repairs</h3><p>Careful support for common fixtures, fittings and day-to-day household issues.</p></article>
          <article class="service-card"><div class="service-number">02</div><h3>Routine Maintenance</h3><p>Preventive checks and scheduled upkeep that help your property stay in good condition.</p></article>
          <article class="service-card"><div class="service-number">03</div><h3>Small Business Support</h3><p>Flexible maintenance assistance for offices, shops and other commercial spaces.</p></article>
        </div>
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="wrap contact-grid">
        <div>
          <p class="kicker">Contact us</p>
          <h2>Tell us what you need</h2>
          <form class="contact-form" action="#contact" method="get">
            <div class="field"><label for="safeName">Your name</label><input id="safeName" type="text" autocomplete="name"></div>
            <div class="field"><label for="safeEmail">Your email</label><input id="safeEmail" type="email" autocomplete="email"></div>
            <div class="field full"><label for="safeSubject">Subject</label><input id="safeSubject" type="text"></div>
            <div class="field full"><label for="safeMessage">Your message</label><textarea id="safeMessage"></textarea></div>
            <div class="field full"><button class="button" type="submit">Submit Request</button></div>
            <p class="form-note">Please include a valid email address so the service team can reply.</p>
          </form>
        </div>
        <aside class="contact-card">
          <h3>Get in touch</h3>
          <div class="contact-item"><strong>Service area</strong><span>Local residential and commercial properties</span></div>
          <div class="contact-item"><strong>Working hours</strong><span>Monday to Saturday, 8:00 AM–6:00 PM</span></div>
          <div class="contact-item"><strong>Response time</strong><span>Most enquiries receive a response within one business day.</span></div>
        </aside>
      </div>
    </section>
  </main>

  <footer>© <%= new Date().getFullYear() %> Repair &amp; Maintenance Services. All rights reserved.</footer>
</body>
</html>
