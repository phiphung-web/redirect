<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Cua hang' %></title>
    <style>
        body { margin: 0; font-family: Arial, sans-serif; background: #f5f0e8; color: #1f2933; }
        .hero { max-width: 980px; margin: 0 auto; padding: 48px 20px 24px; }
        .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
        .brand img { max-height: 48px; max-width: 160px; object-fit: contain; }
        .badge { display: inline-block; padding: 6px 12px; border-radius: 999px; background: #1f2933; color: #fff; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
        h1 { font-size: 42px; margin: 16px 0 10px; }
        p { max-width: 620px; line-height: 1.6; color: #52606d; }
        .grid { max-width: 980px; margin: 0 auto; padding: 0 20px 48px; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
        .card { background: #fff; border-radius: 18px; padding: 18px; box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08); }
        .thumb { height: 160px; border-radius: 14px; background: linear-gradient(135deg, #dbeafe, #fde68a); margin-bottom: 14px; }
        .price { font-weight: 700; color: #7c2d12; }
    </style>
</head>
<body>
    <section class="hero">
        <div class="brand">
            <% if (logo) { %>
                <img src="<%= logo %>" alt="<%= domain %>">
            <% } %>
            <span class="badge"><%= domain %></span>
        </div>
        <h1><%= headline || title || 'San pham noi bat' %></h1>
        <p><%= title || 'Danh muc san pham duoc cap nhat lien tuc, giao dien toi gian de giu luong truy cap tu nhien.' %></p>
    </section>

    <section class="grid">
        <article class="card">
            <div class="thumb"></div>
            <h3>Bo suu tap moi</h3>
            <p>Lua chon san pham ban chay voi giao dien xem nhanh, khong tao nghi ngo cho traffic.</p>
            <div class="price">299.000d</div>
        </article>
        <article class="card">
            <div class="thumb"></div>
            <h3>Combo uu dai</h3>
            <p>Trang noi dung trung tinh, co bo cuc shop co ban de dung lam safe page.</p>
            <div class="price">499.000d</div>
        </article>
        <article class="card">
            <div class="thumb"></div>
            <h3>San pham noi bat</h3>
            <p>Noi dung tinh gon, khong co script la, khong phu thuoc tai nguyen ngoai.</p>
            <div class="price">199.000d</div>
        </article>
    </section>
</body>
</html>
