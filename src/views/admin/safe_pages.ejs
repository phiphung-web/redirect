<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <title>Giao diện mẫu Safe Page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>

<body>
  <%- include('../partials/header', {
    user,
    active: 'safe-pages',
    breadcrumb: [{ label: 'Giao diện mẫu' }]
  }) %>

  <div class="container-xxl pb-5 mt-3">
    <div class="card shadow-sm mb-4">
      <div class="card-body d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div>
          <h3 class="mb-1">Giao diện mẫu Safe Page</h3>
          <div class="text-muted">Tạo và quản lý các mẫu giao diện để chọn nhanh khi tạo link/campaign.</div>
        </div>
        <form method="GET" class="d-flex align-items-end gap-2">
          <div>
            <label class="form-label fw-bold small">Lọc domain</label>
            <select name="domain_id" class="form-select" onchange="this.form.submit()">
              <option value="">Tất cả domain</option>
              <% domains.forEach((domain) => { %>
                <option value="<%= domain.id %>" <%= Number(selectedDomainId) === Number(domain.id) ? 'selected' : '' %>>
                  <%= domain.domain_url %>
                </option>
              <% }) %>
            </select>
          </div>
          <% if (selectedDomainId) { %>
            <a class="btn btn-outline-secondary" href="/safe-pages">Bỏ lọc</a>
          <% } %>
        </form>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header bg-white fw-bold">Thêm mẫu mới</div>
      <form class="card-body" action="/safe-pages/create" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="row g-3 align-items-start">
          <div class="col-lg-7">
            <div class="row g-3">
              <div class="col-md-5">
                <label class="form-label fw-bold">Domain</label>
                <select name="domain_id" class="form-select" required <%= domains.length ? '' : 'disabled' %>>
                  <option value="">Chọn domain</option>
                  <% domains.forEach((domain) => { %>
                    <option value="<%= domain.id %>" <%= Number(selectedDomainId) === Number(domain.id) ? 'selected' : '' %>>
                      <%= domain.domain_url %><%= domain.status === 'active' ? '' : ' (inactive)' %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Tên mẫu</label>
                <input type="text" name="safe_page_name" class="form-control" maxlength="150" placeholder="VD: News Organic" required>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-bold">Template</label>
                <select name="safe_page_template" class="form-select" id="safePageTemplateSelect" onchange="toggleSafePageCustomFields(); renderSafePageBuilderPreview();">
                  <option value="clean">Clean</option>
                  <option value="news">News</option>
                  <option value="shop">Shop</option>
                  <option value="custom">Custom</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Title</label>
                <input type="text" name="safe_page_title" id="safePageTitle" class="form-control" oninput="renderSafePageBuilderPreview()" placeholder="Tin tức 24h">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Headline</label>
                <input type="text" name="safe_page_headline" id="safePageHeadline" class="form-control" oninput="renderSafePageBuilderPreview()" placeholder="Cập nhật mới nhất">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Logo URL</label>
                <input type="url" name="safe_page_logo" id="safePageLogo" class="form-control" oninput="renderSafePageBuilderPreview()">
              </div>
            </div>
            <div class="row g-3 mt-1" id="safePageCustomFields">
              <div class="col-md-7">
                <label class="form-label fw-bold">HTML</label>
                <textarea name="safe_page_custom_html" id="safePageCustomHtml" class="form-control font-monospace" rows="7" oninput="renderSafePageBuilderPreview()" placeholder="<section class='hero'>..."></textarea>
                <div class="form-text">HTML tĩnh cho phần body. Hệ thống sẽ loại bỏ script, form, iframe và event handler.</div>
              </div>
              <div class="col-md-5">
                <label class="form-label fw-bold">CSS</label>
                <textarea name="safe_page_custom_css" id="safePageCustomCss" class="form-control font-monospace" rows="7" oninput="renderSafePageBuilderPreview()" placeholder=".hero { ... }"></textarea>
                <div class="form-text">CSS tĩnh, không dùng @import hoặc javascript URL.</div>
              </div>
            </div>
          </div>
          <div class="col-lg-5">
            <label class="form-label fw-bold">Preview</label>
            <iframe id="safePageBuilderPreview" class="w-100 border rounded bg-white" style="height:320px;" sandbox=""></iframe>
          </div>
        </div>
        <div class="mt-3 text-end">
          <button type="submit" class="btn btn-primary" <%= domains.length ? '' : 'disabled' %>>Thêm mẫu</button>
        </div>
      </form>
    </div>

    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <span class="fw-bold">Danh sách mẫu</span>
        <span class="badge bg-primary"><%= safePages.length %> mẫu</span>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Tên mẫu</th>
              <th>Domain</th>
              <th>Template</th>
              <th>Preview</th>
              <th>Đang dùng</th>
              <th>Trạng thái</th>
              <th class="text-end">Hành động</th>
            </tr>
          </thead>
          <tbody>
            <% if (!safePages.length) { %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">Chưa có mẫu tự tạo.</td>
              </tr>
            <% } %>
            <% safePages.forEach((sp) => { %>
              <tr>
                <td>
                  <b><%= sp.name %></b><br>
                  <small class="text-muted">By <%= sp.created_by_name || 'N/A' %></small>
                </td>
                <td><a href="/domains/<%= sp.domain_id %>" class="text-decoration-none"><%= sp.domain_url %></a></td>
                <td><span class="badge bg-light text-dark border"><%= sp.template %></span></td>
                <td style="width:280px;">
                  <iframe class="w-100 border rounded bg-white safe-page-row-preview" style="height:130px;" sandbox="" data-safe-page-id="<%= sp.id %>"></iframe>
                </td>
                <td><span class="badge bg-secondary"><%= sp.used_by_links || 0 %> link</span></td>
                <td>
                  <form action="/safe-pages/toggle/<%= sp.id %>" method="POST" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="return_to" value="safe-pages">
                    <button type="submit" class="btn btn-sm <%= sp.is_active ? 'btn-success' : 'btn-danger' %>">
                      <%= sp.is_active ? 'ON' : 'OFF' %>
                    </button>
                  </form>
                </td>
                <td class="text-end">
                  <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editSafePageModal-<%= sp.id %>">
                    Sửa
                  </button>
                  <% if (user.role_name === 'super_admin') { %>
                    <form action="/safe-pages/delete/<%= sp.id %>" method="POST" class="d-inline" onsubmit="return confirm('Xóa mẫu safe page này? Campaign đang dùng mẫu này sẽ quay về mặc định domain.')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="return_to" value="safe-pages">
                      <button type="submit" class="btn btn-sm btn-danger"><i class="fa-solid fa-trash"></i></button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <% safePages.forEach((sp) => { %>
    <div class="modal fade" id="editSafePageModal-<%= sp.id %>" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <form class="modal-content" action="/safe-pages/update/<%= sp.id %>" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="return_to" value="safe-pages">
          <div class="modal-header">
            <h5 class="modal-title">Sửa mẫu Safe Page</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Tên mẫu</label>
                <input type="text" name="safe_page_name" class="form-control" maxlength="150" value="<%= sp.name %>" required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Template</label>
                <select name="safe_page_template" class="form-select">
                  <option value="clean" <%= sp.template === 'clean' ? 'selected' : '' %>>Clean</option>
                  <option value="news" <%= sp.template === 'news' ? 'selected' : '' %>>News</option>
                  <option value="shop" <%= sp.template === 'shop' ? 'selected' : '' %>>Shop</option>
                  <option value="custom" <%= sp.template === 'custom' ? 'selected' : '' %>>Custom</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Title</label>
                <input type="text" name="safe_page_title" class="form-control" value="<%= sp.content?.title || '' %>">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Headline</label>
                <input type="text" name="safe_page_headline" class="form-control" value="<%= sp.content?.headline || '' %>">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Logo URL</label>
                <input type="url" name="safe_page_logo" class="form-control" value="<%= sp.content?.logo || '' %>">
              </div>
              <div class="col-md-7">
                <label class="form-label fw-bold">HTML</label>
                <textarea name="safe_page_custom_html" class="form-control font-monospace" rows="8"><%= sp.content?.custom_html || '' %></textarea>
              </div>
              <div class="col-md-5">
                <label class="form-label fw-bold">CSS</label>
                <textarea name="safe_page_custom_css" class="form-control font-monospace" rows="8"><%= sp.content?.custom_css || '' %></textarea>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
            <button type="submit" class="btn btn-primary">Lưu mẫu</button>
          </div>
        </form>
      </div>
    </div>
  <% }) %>

  <script>
    const SAFE_PAGES = <%- JSON.stringify(safePages.map(sp => ({
      id: sp.id,
      name: sp.name,
      template: sp.template,
      content: sp.content || {},
      is_active: sp.is_active
    }))).replace(/</g, '\\u003c') %>;

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, function (char) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char];
      });
    }

    function escapeAttr(value) {
      return escapeHtml(value).replace(/`/g, '&#96;');
    }

    function buildSafePagePreviewHtml(page) {
      const cfg = page.content || {};
      const title = escapeHtml(cfg.title || 'Tin tức 24h');
      const headline = escapeHtml(cfg.headline || 'Cập nhật mới nhất');
      const logo = cfg.logo ? `<img src="${escapeAttr(cfg.logo)}" style="max-height:42px;max-width:160px;margin-bottom:10px;">` : '';
      if (page.template === 'custom') {
        const html = cfg.custom_html || `<main class="fallback"><h1>${headline}</h1><p>${title}</p></main>`;
        const css = cfg.custom_css || '.fallback{min-height:100vh;display:grid;place-items:center;text-align:center;padding:24px;}';
        return `<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><style>body{margin:0;font-family:Arial,sans-serif;}img{max-width:100%;height:auto;}${css}</style></head><body>${html}</body></html>`;
      }
      const palette = page.template === 'shop'
        ? 'background:#f8fafc;color:#172033;--accent:#16a34a;'
        : page.template === 'news'
          ? 'background:#fff7ed;color:#1f2937;--accent:#d97706;'
          : 'background:#f7f8fb;color:#172033;--accent:#2563eb;';
      return `<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><style>body{margin:0;font-family:Arial,sans-serif;${palette}}.wrap{min-height:100vh;display:grid;place-items:center;padding:18px;text-align:center}.card{max-width:520px}.badge{display:inline-block;background:var(--accent);color:white;border-radius:999px;padding:4px 10px;font-size:12px;margin-bottom:10px}h1{font-size:24px;margin:0 0 8px}p{margin:0;color:#667085;font-size:14px}</style></head><body><main class="wrap"><section class="card">${logo}<div class="badge">${escapeHtml(page.template)}</div><h1>${headline}</h1><p>${title}</p></section></main></body></html>`;
    }

    function renderSafePageBuilderPreview() {
      const frame = document.getElementById('safePageBuilderPreview');
      if (!frame) return;
      const page = {
        template: document.getElementById('safePageTemplateSelect')?.value || 'clean',
        content: {
          title: document.getElementById('safePageTitle')?.value || '',
          headline: document.getElementById('safePageHeadline')?.value || '',
          logo: document.getElementById('safePageLogo')?.value || '',
          custom_html: document.getElementById('safePageCustomHtml')?.value || '',
          custom_css: document.getElementById('safePageCustomCss')?.value || ''
        }
      };
      frame.srcdoc = buildSafePagePreviewHtml(page);
    }

    function toggleSafePageCustomFields() {
      const select = document.getElementById('safePageTemplateSelect');
      const fields = document.getElementById('safePageCustomFields');
      if (!select || !fields) return;
      fields.style.display = select.value === 'custom' ? '' : 'none';
    }

    function renderRowPreviews() {
      document.querySelectorAll('.safe-page-row-preview').forEach(frame => {
        const page = SAFE_PAGES.find(sp => String(sp.id) === String(frame.dataset.safePageId));
        if (page) frame.srcdoc = buildSafePagePreviewHtml(page);
      });
    }

    document.addEventListener('DOMContentLoaded', function () {
      toggleSafePageCustomFields();
      renderSafePageBuilderPreview();
      renderRowPreviews();
    });
  </script>
  <%- include('../partials/footer') %>
</body>

</html>
