NODE_ENV=development
PRODUCT_NAME=LinkPilot
PRODUCT_SHORT_NAME=LP
PRODUCT_TAGLINE=Redirect & Campaign Control
PRODUCT_SUPPORT=

ADS_PORT=4001
ADMIN_PORT=4002
BIND_HOST=127.0.0.1
ADS_INSTANCES=4
ADS_MAX_MEMORY_RESTART=700M
TRUST_PROXY=1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=redirect_pro_dev
DB_USER=postgres
DB_PASS=dev_only_change_me
DB_POOL_MAX=8

SESSION_NAME=linkpilot.sid
SESSION_SECRET=dev-session-secret-change-me-before-prod
SESSION_MAX_AGE_MS=86400000
SESSION_SECURE=auto
SESSION_STORE=memory

CACHE_ENABLED=true
CACHE_TTL_MS=30000
CACHE_STALE_TTL_MS=300000
CACHE_MAX_ENTRIES=5000
TRAFFIC_BUFFER_ENABLED=false
TRAFFIC_BATCH_SIZE=100
TRAFFIC_FLUSH_MS=1000
TRAFFIC_QUEUE_MAX=10000
COUNTER_BUFFER_ENABLED=false
COUNTER_FLUSH_MS=2000

LOG_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=./backups

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_ALERT_COOLDOWN_MINUTES=15
MONITOR_EXPECTED_IPV4=
AUDIT_FILE_PATH=./logs/audit.log
AUDIT_FILE_MAX_MB=20
AUDIT_RETENTION_DAYS=7
