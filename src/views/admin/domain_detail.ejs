            $(document).ready(function () {
                const select = $('#countrySelect');
                for (let [code, name] of Object.entries(ALL_COUNTRIES)) {
                    select.append(new Option(`${name} (${code})`, code));
                }
                select.select2({ placeholder: "Chọn quốc gia...", dropdownParent: $('#addLinkModal') });
            });

            function addNewRule(key = '', op = 'exists', val = '') {
                let html = `
                <div class="row g-2 mb-2 rule-row align-items-center">
                    <div class="col-4"><input type="text" class="form-control form-control-sm rule-key" placeholder="Key (vd: fbclid)" value="${escapeAttr(key)}" oninput="updateRulesQueryString()"></div>
                    <div class="col-3">
                        <select class="form-select form-select-sm rule-op" onchange="toggleVal(this); updateRulesQueryString();">
                            <option value="exists" ${op === 'exists' ? 'selected' : ''}>Tồn tại</option>
                            <option value="equals" ${op === 'equals' ? 'selected' : ''}>Bằng (=)</option>
                        </select>
                    </div>
                    <div class="col-4"><input type="text" class="form-control form-control-sm rule-val" value="${escapeAttr(val)}" ${op === 'exists' ? 'disabled' : ''} placeholder="Giá trị" oninput="updateRulesQueryString()"></div>
                    <div class="col-1"><button type="button" class="btn btn-sm text-danger" onclick="this.closest('.rule-row').remove(); updateRulesQueryString();">x</button></div>
                </div>`;
                $('#rules-wrapper').append(html);
                updateRulesQueryString();
            }

            function toggleVal(sel) {
                const inp = sel.closest('.rule-row').querySelector('.rule-val');
                inp.disabled = (sel.value === 'exists');
                if (inp.disabled) inp.value = '';
                updateRulesQueryString();
            }

            function addTemplate(t) {
                $('#rules-wrapper').empty();
                if (t === 'fb') {
                    addNewRule('utm_source', 'equals', 'facebook');
                    addNewRule('fbclid', 'exists');
                    addNewRule('campaign_id', 'exists');
                    addNewRule('adset_id', 'exists');
                    addNewRule('ad_id', 'exists');
                    addNewRule('placement', 'exists');
                }
                else if (t === 'gg') {
                    addNewRule('utm_source', 'equals', 'google');
                    addNewRule('gclid', 'exists');
                    addNewRule('campaignid', 'exists');
                    addNewRule('adgroupid', 'exists');
                    addNewRule('keyword', 'exists');
                }
                else if (t === 'tiktok') {
                    addNewRule('utm_source', 'equals', 'tiktok');
                    addNewRule('ttclid', 'exists');
                }
                updateRulesQueryString();
            }

            function collectRules() {
                let rules = [];
                $('.rule-row').each(function () {
                    let k = $(this).find('.rule-key').val();
                    let o = $(this).find('.rule-op').val();
                    let v = $(this).find('.rule-val').val();
                    if (k) rules.push({ key: k, operator: o, value: v });
                });
                return rules;
            }

            function buildRulesQueryString() {
                return collectRules().map(rule => {
                    const value = rule.operator === 'equals' && rule.value ? rule.value : 'xxx';
                    return `${encodeURIComponent(rule.key)}=${encodeURIComponent(value)}`;
                }).join('&');
            }

            function updateRulesQueryString() {
                const input = document.getElementById('rulesQueryString');
                if (input) input.value = buildRulesQueryString();
            }

            function copyGeneratedParams() {
                const el = document.getElementById('rulesQueryString');
                if (!el) return;
                el.select();
                document.execCommand("copy");
                alert("Đã copy chuỗi tham số");
            }

            function checkDNS(id) {
                const token = document.getElementById('csrfToken').value;
                fetch(`/domains/${id}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `_csrf=${encodeURIComponent(token)}`
                }).then(r => r.json()).then(d => { alert(d.msg); location.reload(); });
            }

            function copyLink(id) {
                const el = document.getElementById(id);
                el.select();
                document.execCommand("copy");
                alert("Đã copy");
            }

            function onCopySelect() {
                const id = document.getElementById('copyFromSelect').value;
                document.getElementById('copy_from_id').value = id;
                if (!id) {
                    document.getElementById('configPreview').innerText = 'Chọn link để xem cấu hình.';
                    $('#campaignSafePageSelect').val('').trigger('change');
                    renderCampaignSafePagePreview();
                    return;
                }
                fetch(`/api/campaigns/${id}/config`).then(r => r.json()).then(cfg => {
                    const rules = (cfg.rules || []).map(r => `${r.key} (${r.operator}${r.value ? ':' + r.value : ''})`).join(', ');
                    const countries = (cfg.filters && cfg.filters.countries && cfg.filters.countries.length) ? cfg.filters.countries.join(', ') : 'All';
                    document.getElementById('configPreview').innerText = `Rules: ${rules || 'Mặc định'} | Countries: ${countries}`;
                    $('#rules-wrapper').empty();
                    (cfg.rules || []).forEach(r => addNewRule(r.key, r.operator, r.value));
                    $('#countrySelect').val(cfg.filters?.countries || []).trigger('change');
                    $('#campaignSafePageSelect').val(cfg.safe_page_id || '').trigger('change');
                    renderCampaignSafePagePreview();
                    updateRulesQueryString();
                }).catch(() => document.getElementById('configPreview').innerText = 'Không tải được cấu hình');
            }

            $('#createForm').on('submit', function () {
                $('#rules_json').val(JSON.stringify(collectRules()));
            });
