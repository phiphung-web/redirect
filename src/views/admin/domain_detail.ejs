<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Quản lý - <%= domain.domain_url %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
            font-family: sans-serif;
        }

        .select2-container {
            width: 100% !important;
            z-index: 9999;
        }

        .suggestion-box {
            background: #fff3cd;
            padding: 6px;
            border-radius: 4px;
            font-size: 0.85rem;
            margin-top: 6px;
        }
    </style>
</head>

<body>
    <%- include('../partials/header', { user, active: 'redirect' , backUrl: '/redirect' , breadcrumb: [ {
        label: 'Redirect' , url: '/redirect' }, { label: domain.domain_url } ] }) %>
        <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

        <div class="container pb-5 mt-3">
            <div class="card mb-4 shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-1 text-primary">
                            <%= domain.domain_url %>
                        </h3>
                        <span class="badge bg-secondary">Giao diện sạch: <%= domain.safe_template %></span>
                        <span class="badge <%= domain.status === 'active' ? 'bg-success' : 'bg-warning' %>">
                            <%= domain.status.toUpperCase() %>
                        </span>
                        <div class="text-muted small mt-1">Tạo: <%= domain.created_by_name || 'N/A' %> @ <%= new
                                    Date(domain.created_at).toLocaleString('vi-VN') %> | Cập nhật: <%=
                                        domain.updated_by_name || domain.created_by_name || '-' %> @ <%=
                                            domain.updated_at ? new Date(domain.updated_at).toLocaleString('vi-VN')
                                            : '-' %>
                        </div>
                        <% if (linkStats) { %>
                            <div class="mt-2">
                                <span class="badge bg-primary">Tổng link: <%= linkStats.total %></span>
                                <span class="badge bg-success">ON: <%= linkStats.active %></span>
                                <span class="badge bg-secondary">OFF: <%= linkStats.total - linkStats.active %></span>
                            </div>
                            <% } %>
                    </div>
                    <div>
                        <button class="btn btn-outline-primary me-2" onclick="checkDNS('<%= domain.id %>')">Check
                            DNS</button>
                        <button class="btn btn-success fw-bold" data-bs-toggle="modal" data-bs-target="#addLinkModal">+
                            Tạo Link Mới</button>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <div class="fw-bold">Safe Page mặc định của domain</div>
                    <div class="text-muted small">Dùng khi link/campaign chưa chọn mẫu riêng, không match campaign, short link lỗi/OFF hoặc hệ thống cần fallback an toàn.</div>
                </div>
                <form class="card-body" action="/domains/<%= domain.id %>/safe-content" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Template mặc định</label>
                            <select name="safe_template" class="form-select" id="safeTemplateSelect" onchange="toggleCustomSafeFields(); renderDomainSafeDefaultPreview();">
                                <option value="clean" <%= domain.safe_template === 'clean' ? 'selected' : '' %>>Clean</option>
                                <option value="news" <%= domain.safe_template === 'news' ? 'selected' : '' %>>News</option>
                                <option value="shop" <%= domain.safe_template === 'shop' ? 'selected' : '' %>>Shop</option>
                                <option value="custom" <%= domain.safe_template === 'custom' ? 'selected' : '' %>>Custom</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Title</label>
                            <input type="text" name="safe_title" id="domainSafeTitle" class="form-control" value="<%= domain.safe_content?.title || '' %>" oninput="renderDomainSafeDefaultPreview()">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Headline</label>
                            <input type="text" name="safe_headline" id="domainSafeHeadline" class="form-control" value="<%= domain.safe_content?.headline || '' %>" oninput="renderDomainSafeDefaultPreview()">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Logo URL</label>
                            <input type="url" name="safe_logo" id="domainSafeLogo" class="form-control" value="<%= domain.safe_content?.logo || '' %>" oninput="renderDomainSafeDefaultPreview()">
                        </div>
                    </div>
                    <div class="row g-3 mt-1" id="customSafeFields">
                        <div class="col-md-7">
                            <label class="form-label fw-bold">Custom HTML</label>
                            <textarea name="safe_custom_html" id="domainSafeCustomHtml" class="form-control font-monospace" rows="9" placeholder="<section class='hero'>..." oninput="renderDomainSafeDefaultPreview()"><%= domain.safe_content?.custom_html || '' %></textarea>
                            <div class="form-text">HTML tĩnh cho phần body. Hệ thống sẽ loại bỏ script, form, iframe và event handler.</div>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Custom CSS</label>
                            <textarea name="safe_custom_css" id="domainSafeCustomCss" class="form-control font-monospace" rows="9" placeholder=".hero { ... }" oninput="renderDomainSafeDefaultPreview()"><%= domain.safe_content?.custom_css || '' %></textarea>
                            <div class="form-text">CSS tĩnh, không dùng @import hoặc javascript URL.</div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-bold">Preview mặc định</label>
                        <iframe id="domainSafeDefaultPreview" class="w-100 border rounded bg-white" style="height:220px;" sandbox=""></iframe>
                    </div>
                    <div class="mt-3 text-end">
                        <button type="submit" class="btn btn-outline-primary">Lưu mặc định</button>
                    </div>
                </form>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Thư viện mẫu Safe Page</span>
                    <span class="badge bg-primary"><%= safePages.length %> mẫu</span>
                </div>
                <div class="card-body">
                    <form action="/domains/<%= domain.id %>/safe-pages/create" method="POST" class="border rounded p-3 bg-light mb-4">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Tên mẫu</label>
                                <input type="text" name="safe_page_name" class="form-control" maxlength="150" placeholder="VD: News Organic" required>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-bold">Template</label>
                                <select name="safe_page_template" class="form-select" id="safePageTemplateSelect" onchange="toggleSafePageCustomFields(); renderSafePageBuilderPreview();">
                                    <option value="clean">Clean</option>
                                    <option value="news">News</option>
                                    <option value="shop">Shop</option>
                                    <option value="custom">Custom</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">Title</label>
                                <input type="text" name="safe_page_title" id="safePageTitle" class="form-control" oninput="renderSafePageBuilderPreview()" placeholder="Tin tức 24h">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">Headline</label>
                                <input type="text" name="safe_page_headline" id="safePageHeadline" class="form-control" oninput="renderSafePageBuilderPreview()" placeholder="Cập nhật mới nhất">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Logo URL</label>
                                <input type="url" name="safe_page_logo" id="safePageLogo" class="form-control" oninput="renderSafePageBuilderPreview()">
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Preview</label>
                                <iframe id="safePageBuilderPreview" class="w-100 border rounded bg-white" style="height:180px;" sandbox=""></iframe>
                            </div>
                        </div>
                        <div class="row g-3 mt-1" id="safePageCustomFields">
                            <div class="col-md-7">
                                <label class="form-label fw-bold">HTML</label>
                                <textarea name="safe_page_custom_html" id="safePageCustomHtml" class="form-control font-monospace" rows="7" oninput="renderSafePageBuilderPreview()" placeholder="<section class='hero'>..."></textarea>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-bold">CSS</label>
                                <textarea name="safe_page_custom_css" id="safePageCustomCss" class="form-control font-monospace" rows="7" oninput="renderSafePageBuilderPreview()" placeholder=".hero { ... }"></textarea>
                            </div>
                        </div>
                        <div class="mt-3 text-end">
                            <button type="submit" class="btn btn-primary">Thêm mẫu</button>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Tên mẫu</th>
                                    <th>Template</th>
                                    <th>Preview</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!safePages.length) { %>
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-3">Chưa có mẫu riêng. Link sẽ dùng safe page mặc định của domain.</td>
                                    </tr>
                                <% } %>
                                <% safePages.forEach((sp) => { %>
                                    <tr>
                                        <td>
                                            <b><%= sp.name %></b><br>
                                            <small class="text-muted">By <%= sp.created_by_name || 'N/A' %></small>
                                        </td>
                                        <td><span class="badge bg-light text-dark border"><%= sp.template %></span></td>
                                        <td style="width:260px;">
                                            <iframe class="w-100 border rounded bg-white safe-page-row-preview" style="height:120px;" sandbox="" data-safe-page-id="<%= sp.id %>"></iframe>
                                        </td>
                                        <td>
                                            <form action="/safe-pages/toggle/<%= sp.id %>" method="POST" class="d-inline">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="btn btn-sm <%= sp.is_active ? 'btn-success' : 'btn-danger' %>">
                                                    <%= sp.is_active ? 'ON' : 'OFF' %>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editSafePageModal-<%= sp.id %>">
                                                Sửa
                                            </button>
                                            <% if (user.role_name === 'super_admin') { %>
                                                <form action="/safe-pages/delete/<%= sp.id %>" method="POST" class="d-inline" onsubmit="return confirm('Xóa mẫu safe page này? Campaign đang dùng mẫu này sẽ quay về mặc định domain.')">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tên Camp</th>
                            <th>Link Chạy Ads</th>
                            <th>Rules</th>
                            <th>Trạng thái</th>
                            <th>Thống kê</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (links.length===0) { %>
                            <tr>
                                <td colspan="6" class="text-center py-4">Chưa có link nào.</td>
                            </tr>
                            <% } %>
                                <% links.forEach(l=> { %>
                                    <tr>
                                        <td>
                                            <b>
                                                <%= l.name %>
                                            </b><br>
                                            <small class="text-muted d-block text-truncate" style="max-width: 200px;">
                                                <%= l.target_url %>
                                            </small>
                                            <small class="text-muted d-block">Safe Page: <%= l.safe_page_name || 'Mặc định domain' %></small>
                                            <small class="text-muted">By <%= l.created_by_name || 'N/A' %> | Update: <%=
                                                        l.updated_by_name || l.created_by_name || '-' %></small>
                                        </td>
                                        <td>
                                            <div class="input-group input-group-sm">
                                                <input type="text" class="form-control bg-white text-primary fw-bold"
                                                    value="<%= l.full_url %>" readonly id="link-<%= l.id %>">
                                                <button class="btn btn-primary" onclick="copyLink('link-<%= l.id %>')"
                                                    title="Copy Link"><i class="fas fa-copy"></i></button>
                                            </div>
                                            <div class="mt-1"><span class="badge bg-light text-secondary border">Auto
                                                    ID: <%= l.param_value %></span></div>
                                        </td>
                                        <td>
                                            <small>
                                                <% if(l.rules && l.rules.length) { %>
                                                    Check: <b>
                                                        <%= l.rules.length %>
                                                    </b> tham số<br>
                                                    Quốc gia: <%= (l.filters && l.filters.countries &&
                                                        l.filters.countries.length) ? l.filters.countries.join(',')
                                                        : 'All' %>
                                                        <% } else { %>
                                                            Mặc định
                                                            <% } %>
                                            </small>
                                        </td>
                                        <td>
                                            <form action="/campaigns/toggle/<%= l.id %>" method="POST" class="d-inline"
                                                onsubmit="return confirm('Đổi trạng thái ON/OFF cho link này?')">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit"
                                                    class="btn btn-sm <%= l.is_active ? 'btn-success' : 'btn-danger' %>">
                                                    <%= l.is_active ? 'ON' : 'OFF' %>
                                                </button>
                                            </form>
                                            <% if(l.suggestion) { %>
                                                <div class="suggestion-box text-warning">Nhiều traffic an toàn 24h: <%=
                                                        l.safe_24h || 0 %>. Nên bật link.</div>
                                                <% } %>
                                        </td>
                                        <td>
                                            <div><b>
                                                    <%= l.stats_redirects %>
                                                </b> pass</div>
                                            <div class="text-muted small">Fail 24h: <%= l.safe_24h || 0 %>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <a href="/campaigns/edit/<%= l.id %>"
                                                class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                            <a href="/campaigns/<%= l.id %>/report"
                                                class="btn btn-sm btn-info text-white"><i
                                                    class="fas fa-chart-bar"></i></a>
                                            <% if (user.role_name==='super_admin' ) { %>
                                                <form action="/campaigns/delete/<%= l.id %>" method="POST" class="d-inline"
                                                    onsubmit="return confirm('Cảnh báo: Xóa link sẽ xóa thống kê/log liên quan. Tiếp tục?')">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button type="submit" class="btn btn-sm btn-danger"><i
                                                            class="fas fa-trash"></i></button>
                                                </form>
                                                <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <% safePages.forEach((sp) => { %>
            <div class="modal fade" id="editSafePageModal-<%= sp.id %>" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <form class="modal-content" action="/safe-pages/update/<%= sp.id %>" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="modal-header">
                            <h5 class="modal-title">Sửa mẫu Safe Page</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Tên mẫu</label>
                                    <input type="text" name="safe_page_name" class="form-control" maxlength="150" value="<%= sp.name %>" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Template</label>
                                    <select name="safe_page_template" class="form-select">
                                        <option value="clean" <%= sp.template === 'clean' ? 'selected' : '' %>>Clean</option>
                                        <option value="news" <%= sp.template === 'news' ? 'selected' : '' %>>News</option>
                                        <option value="shop" <%= sp.template === 'shop' ? 'selected' : '' %>>Shop</option>
                                        <option value="custom" <%= sp.template === 'custom' ? 'selected' : '' %>>Custom</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Title</label>
                                    <input type="text" name="safe_page_title" class="form-control" value="<%= sp.content?.title || '' %>">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Headline</label>
                                    <input type="text" name="safe_page_headline" class="form-control" value="<%= sp.content?.headline || '' %>">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Logo URL</label>
                                    <input type="url" name="safe_page_logo" class="form-control" value="<%= sp.content?.logo || '' %>">
                                </div>
                                <div class="col-md-7">
                                    <label class="form-label fw-bold">HTML</label>
                                    <textarea name="safe_page_custom_html" class="form-control font-monospace" rows="8"><%= sp.content?.custom_html || '' %></textarea>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label fw-bold">CSS</label>
                                    <textarea name="safe_page_custom_css" class="form-control font-monospace" rows="8"><%= sp.content?.custom_css || '' %></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-primary">Lưu mẫu</button>
                        </div>
                    </form>
                </div>
            </div>
        <% }) %>

        <div class="modal fade" id="addLinkModal" data-bs-backdrop="static">
            <div class="modal-dialog modal-lg">
                <form class="modal-content" action="/campaigns/create" method="POST" id="createForm">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="modal-header">
                        <h5 class="modal-title">Tạo Link Ads Mới</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="domain_id" value="<%= domain.id %>">
                        <input type="hidden" name="copy_from_id" id="copy_from_id">

                        <div class="alert alert-info py-2 small"><i class="fas fa-bolt"></i> Link sẽ được sinh tự động
                            (VD: ?q=AbC123) sau khi lưu.</div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="fw-bold">Tên Chiến Dịch</label>
                                <input type="text" name="name" class="form-control" required>
                            </div>
                            <div class="col-6">
                                <label class="fw-bold">Link Đích (Target)</label>
                                <input type="url" name="target_url" class="form-control" required>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-5">
                                <label class="fw-bold">Mẫu Safe Page</label>
                                <select name="safe_page_id" class="form-select" id="campaignSafePageSelect" onchange="renderCampaignSafePagePreview()">
                                    <option value="">Mặc định domain</option>
                                    <% safePages.filter(sp => sp.is_active).forEach(sp => { %>
                                        <option value="<%= sp.id %>"><%= sp.name %> (<%= sp.template %>)</option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-7">
                                <label class="fw-bold">Preview Safe Page</label>
                                <iframe id="campaignSafePagePreview" class="w-100 border rounded bg-white" style="height:170px;" sandbox=""></iframe>
                            </div>
                        </div>

                        <hr>
                        <div class="mb-3">
                            <label class="fw-bold">Quốc gia cho phép</label>
                            <select class="form-control select2-countries" name="allowed_countries[]"
                                multiple="multiple" id="countrySelect"></select>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Sao chép cấu hình từ link sẵn có</label>
                            <select class="form-control" id="copyFromSelect" onchange="onCopySelect()">
                                <option value="">-- Không sao chép --</option>
                                <% links.forEach(l=> { %>
                                    <option value="<%= l.id %>">
                                        <%= l.name %>
                                    </option>
                                    <% }) %>
                            </select>
                            <div class="border rounded mt-2 p-2 bg-light" id="configPreview"
                                style="min-height:60px;font-size:0.9rem;">
                                Chọn link để xem cấu hình.
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="fw-bold">Luật kiểm tra</label>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown">Mẫu Nhanh</button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" onclick="addTemplate('fb')">Facebook Ads</a>
                                    </li>
                                    <li><a class="dropdown-item" href="#" onclick="addTemplate('gg')">Google Ads</a>
                                    </li>
                                    <li><a class="dropdown-item" href="#" onclick="addTemplate('tiktok')">TikTok Ads</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div id="rules-wrapper" class="border rounded p-2 mb-2 bg-light"></div>
                        <button type="button" class="btn btn-sm btn-secondary w-100" onclick="addNewRule()">+ Thêm điều
                            kiện</button>
                        <div class="mt-3">
                            <label class="fw-bold">Chuỗi tham số mẫu</label>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control bg-white" id="rulesQueryString" readonly value="">
                                <button type="button" class="btn btn-outline-primary" onclick="copyGeneratedParams()">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                            <div class="form-text">Dùng ký tự & chuẩn URL, ví dụ: utm_source=facebook&utm_campaign=xxx</div>
                        </div>
                        <input type="hidden" name="rules_json" id="rules_json">
                    </div>
                    <div class="modal-footer"><button class="btn btn-primary w-100">Tạo Link Ngay</button></div>
                </form>
            </div>
        </div>

