<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Chi tiết Link - <%= camp.name %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container {
            width: 100% !important;
        }

        .select2-selection__choice {
            background-color: #0d6efd !important;
            color: white !important;
            border: none;
        }
    </style>
</head>

<body>
    <% const visibleProjects = typeof projects !== 'undefined' && Array.isArray(projects) ? projects : []; %>
    <%- include('../partials/header', { user, active: 'redirect' , backUrl: '/domains/' + domain.id, breadcrumb: [ {
        label: 'Redirect' , url: '/redirect' }, { label: domain.domain_url, url: '/domains/' + domain.id }, {
        label: 'Chi tiết link' } ] }) %>
        <div class="container bg-white p-4 rounded shadow-sm mt-3" style="max-width: 900px;">
            <div class="d-flex justify-content-between mb-4">
                <div>
                    <h3 class="mb-0" data-help="Chỉnh URL đích, phạm vi quốc gia và các quy tắc tham số của chiến dịch. Thay đổi có thể mất tối đa 30 giây để hết cache.">Chi tiết link: <span class="text-primary">
                            <%= camp.name %>
                        </span></h3>
                    <small class="text-muted">ID: <%= camp.id %> | Domain: <%= domain.domain_url %></small><br>
                    <small class="text-muted">Tạo: <%= camp.created_by_name || 'N/A' %> @ <%= new
                                Date(camp.created_at).toLocaleString('vi-VN') %> | Cập nhật: <%= camp.updated_by_name ||
                                    camp.created_by_name || '-' %> @ <%= camp.updated_at ? new
                                        Date(camp.updated_at).toLocaleString('vi-VN') : '-' %></small>
                </div>
                <div></div>
            </div>

            <div class="card mb-3">
                <div class="card-body">
                    <p><b>Param key:</b>
                        <%= camp.param_key %> | <b>Param value:</b>
                            <%= camp.param_value %>
                    </p>
                    <p><b>Link đích:</b> <span class="text-break">
                            <%= camp.target_url %>
                        </span></p>
                </div>
            </div>

            <form action="/campaigns/update/<%= camp.id %>" method="POST" id="editForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="domain_id" value="<%= camp.domain_id %>">
                <input type="hidden" name="rules_json" id="rules_json">

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="fw-bold" data-help="Tên nội bộ giúp phân biệt chiến dịch trong dashboard, log và báo cáo.">Tên Chiến Dịch</label>
                        <input type="text" name="name" class="form-control" value="<%= camp.name %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold" data-help="URL được sử dụng khi tham số khớp và toàn bộ bộ lọc của chiến dịch đều đạt.">Link Đích (Target)</label>
                        <input type="url" name="target_url" class="form-control" value="<%= camp.target_url %>"
                            required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="fw-bold" data-help="Có thể chuyển link sang dự án khác hoặc để Chưa phân loại. URL và rule không thay đổi.">Dự án</label>
                    <select class="form-select" name="project_id">
                        <option value="">Chưa phân loại</option>
                        <% visibleProjects.forEach(project => { %>
                            <option value="<%= project.id %>" <%= Number(project.id) === Number(camp.project_id) ? 'selected' : '' %> <%= project.status !== 'active' && Number(project.id) !== Number(camp.project_id) ? 'disabled' : '' %>><%= project.name %><%= project.status !== 'active' ? ' · Đã lưu trữ' : '' %><%= Number(project.user_id) === Number(user.id) ? '' : ' · ' + project.owner_name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="fw-bold" data-help="Chỉ các mã quốc gia được chọn mới đi tới link đích. Để trống nếu chiến dịch không giới hạn quốc gia.">Quốc gia cho phép</label>
                    <select class="form-control select2-countries" name="allowed_countries[]" multiple="multiple"
                        id="countrySelect"></select>
                    <small class="text-muted">Để trống = Tất cả quốc gia.</small>
                </div>

                <label class="fw-bold mb-2" data-help="Mỗi rule kiểm tra một query parameter. Tồn tại chỉ yêu cầu có key; Bằng yêu cầu đúng cả key và giá trị.">Quy tắc Tham số (Rules)</label>
                <div class="row g-2 px-3 mb-1 d-none d-md-flex small text-muted fw-semibold"><div class="col-md-4">Tên tham số</div><div class="col-md-3">Kiểm tra</div><div class="col-md-4">Giá trị cần khớp</div><div class="col-md-1"></div></div>
                <div id="rules-wrapper" class="bg-light p-3 rounded border mb-3"></div>
                <button type="button" class="btn btn-sm btn-secondary" onclick="addNewRule()">+ Thêm điều kiện</button>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-primary px-5">Lưu Thay đổi</button>
                </div>
            </form>
        </div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
